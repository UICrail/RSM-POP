###  https://cdm.ovh/examples#port1_0
work:port1_0 rdf:type owl:NamedIndividual ,
                      topo:Port ;
             topo:onElement work:lin1 ;
             rdfs:label "port1_0" ;
             rgeo:hasGeometry work:port1_0_geometry .


###  https://cdm.ovh/examples#port1_0_geometry
work:port1_0_geometry rdf:type owl:NamedIndividual ,
                               rgeo:Geometry ;
                      geo:asWKT "POINT (394110.0 6537160.0)" ;
                      rgeo:asWKT "POINT (394110.0 6537160.0)" ;
                      rgeo:geometryOf work:port1_0 .


###  https://cdm.ovh/examples#port1_1
work:port1_1 rdf:type owl:NamedIndividual ,
                      topo:Port ;
             topo:connectedWith work:port2_0 ,
                                work:port4_0 ;
             topo:navigableTo work:port2_1 ,
                              work:port4_1 ;
             topo:onElement work:lin1 ;
             rdfs:label "port1_1" ;
             rgeo:hasGeometry work:port1_1_geometry .


###  https://cdm.ovh/examples#port1_1_geometry
