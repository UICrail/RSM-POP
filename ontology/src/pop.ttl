@prefix : <https://cdm.ovh/rsm/pop/pop#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix dul: <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pop: <https://cdm.ovh/rsm/pop/pop#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix sosa: <http://www.w3.org/ns/sosa/> .
@base <https://cdm.ovh/rsm/pop/pop> .

<https://cdm.ovh/rsm/pop/pop> rdf:type owl:Ontology ;
                               owl:versionIRI <https://cdm.ovh/rsm/pop/0.2/pop> ;
                               dc:creator "Airy Magnien" ;
                               dc:date "17 June 2026" ;
                               dc:description """Ontology for Prescriptions (subclass of dul:Description), Observations, Predictions. Built on DUL, PROV-O, and SOSA/SSN. Also considers Specifications and Corrections (as subclasses of Prescriptions).

POPs and Current State of some Digital Twin (out of scope here) are formally similar, but epistemically quite different: POPs are facts, hence immutable. Facts can be erroneous or incomplete or obsolete, but remain as they were delivered or computed until they get discarded."""@en ;
                               dc:license <https://creativecommons.org/licenses/by-sa/4.0/> ;
                               dc:title "Prescription, Observation, Prediction ontology"@en ;
                               rdfs:comment "All imports were eliminated after overall consistency between DUL, SOSA/SSN, and POP was ascertained."@en ;
                               owl:versionInfo "0.2: time dimension removed (expected to be handled with dul:Situation or similar). IRI refactoring and conceptual cleanup."@en .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/elements/1.1/creator
dc:creator rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/date
dc:date rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/description
dc:description rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/license
dc:license rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/title
dc:title rdf:type owl:AnnotationProperty .


###  https://cdm.ovh/rsm/pop/pop#aboutProperty
pop:aboutProperty rdf:type owl:AnnotationProperty ;
                  rdfs:comment "References the external property (rdf:Property, owl:ObjectProperty, owl:DatatypeProperty, reified property, ...) that an AssertedQuality is about. Ignored by OWL reasoners; provides semantic context only."@en ;
                  rdfs:label "about property"@en .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#dateTime
xsd:dateTime rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  https://cdm.ovh/rsm/pop/pop#aboutEntity
pop:aboutEntity rdf:type owl:ObjectProperty ;
                rdfs:domain pop:AssertedQuality ;
                rdfs:range dul:Entity ;
                rdfs:label "about entity"@en .


###  https://cdm.ovh/rsm/pop/pop#aggregationRule
pop:aggregationRule rdf:type owl:ObjectProperty ,
                             owl:FunctionalProperty ;
                    rdfs:domain pop:IntensiveQuality ;
                    rdfs:range skos:Concept ;
                    rdfs:label "aggregation rule"@en .


###  https://cdm.ovh/rsm/pop/pop#assertedBy
pop:assertedBy rdf:type owl:ObjectProperty ;
               rdfs:domain pop:AssertedQuality ;
               rdfs:range pop:AssertionGeneratingActivity ;
               rdfs:label "asserted by" .


###  https://cdm.ovh/rsm/pop/pop#boundariesNode
pop:boundariesNode rdf:type owl:ObjectProperty ;
                   rdfs:domain pop:AssertedValue ;
                   rdfs:comment "Can be expressed as an interval (hence \"boundaries\"), or a distribution, a confidence interval, etc."@en ;
                   rdfs:label "boundaries node"@en .


###  https://cdm.ovh/rsm/pop/pop#hasAssertedValue
pop:hasAssertedValue rdf:type owl:ObjectProperty ,
                              owl:FunctionalProperty ;
                     rdfs:domain pop:AssertedQuality ;
                     rdfs:range pop:AssertedValue ;
                     rdfs:label "has asserted value"@en .


###  https://cdm.ovh/rsm/pop/pop#valueNode
pop:valueNode rdf:type owl:ObjectProperty ;
              rdfs:domain pop:AssertedValue ;
              rdfs:comment "valueNode points to any resource (possibly an IRI, a string, a blank node...) holding the value of a property. It may be the original value provided by an RDF data source. Data type (if applicable) and data constraints are entirely the responsibility of the source."@en ;
              rdfs:label "value node"@en .


#################################################################
#    Data properties
#################################################################

###  https://cdm.ovh/rsm/pop/pop#hasSimpleResult
pop:hasSimpleResult rdf:type owl:DatatypeProperty ;
                    rdfs:domain pop:AssertedQuality ;
                    rdfs:comment "Generalization of sosa:hasSimpleResult"@en ;
                    rdfs:label "has simple result" .


###  https://cdm.ovh/rsm/pop/pop#resultTime
pop:resultTime rdf:type owl:DatatypeProperty ;
               rdfs:domain pop:AssertedQuality ;
               rdfs:range xsd:dateTime ;
               rdfs:comment "generalisation of sosa:resultTime"@en ;
               rdfs:label "result time"@en .


#################################################################
#    Classes
#################################################################

###  http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Entity
dul:Entity rdf:type owl:Class ;
           rdfs:label "Entity"@en .


###  http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#InformationObject
dul:InformationObject rdf:type owl:Class .


###  http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Process
dul:Process rdf:type owl:Class .


###  http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Region
dul:Region rdf:type owl:Class .


###  http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#TimeInterval
dul:TimeInterval rdf:type owl:Class .


###  http://www.w3.org/2004/02/skos/core#Concept
skos:Concept rdf:type owl:Class ;
             rdfs:comment "possible concepts describing the effect of aggregation on the property value, in a concept scheme to be defined: maximum / minimum / product / logical AND / logical OR / list / undefined / weighted average / ..."@en ;
             rdfs:label "concept"@en .


###  http://www.w3.org/ns/prov#Activity
prov:Activity rdf:type owl:Class .


###  http://www.w3.org/ns/sosa/Observation
sosa:Observation rdf:type owl:Class .


###  https://cdm.ovh/rsm/pop/pop#AssertedQuality
pop:AssertedQuality rdf:type owl:Class ;
                    rdfs:subClassOf dul:InformationObject ;
                    rdfs:comment "The externally defined property (NOT: PROPERTY VALUE) that AssertedQuality refers to shall be indicated using pop:aboutProperty, which is an owl:AnnotationProperty. pop:aboutProperty can target any rdf resource, such as a class, an object property, a data property, as long as that resource unambiguously defines what property is meant (from a domain point of view)."@en ;
                    rdfs:label "Asserted quality"@en .


###  https://cdm.ovh/rsm/pop/pop#AssertedTimeInterval
pop:AssertedTimeInterval rdf:type owl:Class ;
                         rdfs:subClassOf dul:TimeInterval ;
                         rdfs:comment "a sosa:resultTime is equivalent to a degenerated pop:AssertedInterval. In general, if the observation period is an interval, it will result in an AssertedInterval ending at the resultTime."@en ;
                         rdfs:label "Asserted time interval"@en .


###  https://cdm.ovh/rsm/pop/pop#AssertedValue
pop:AssertedValue rdf:type owl:Class ;
                  rdfs:subClassOf dul:Region ;
                  rdfs:comment "The value (quality or quantity) and its uncertainty or tolerance, in most generic form."@en ;
                  rdfs:label "Asserted value" .


###  https://cdm.ovh/rsm/pop/pop#AssertionGeneratingActivity
pop:AssertionGeneratingActivity rdf:type owl:Class ;
                                rdfs:subClassOf dul:Process ,
                                                prov:Activity ;
                                rdfs:label "Assertion-generating activity" .


###  https://cdm.ovh/rsm/pop/pop#Correction
pop:Correction rdf:type owl:Class ;
               rdfs:subClassOf pop:AssertionGeneratingActivity ;
               rdfs:label "Correction"@en .


###  https://cdm.ovh/rsm/pop/pop#Estimation
pop:Estimation rdf:type owl:Class ;
               rdfs:subClassOf pop:AssertionGeneratingActivity ;
               rdfs:comment "another source kind that may involve data gap-filling, intra- or extrapolation, filtering, reconciliation, and assorted decision points. Usually resting on multiple sources."@en ;
               rdfs:label "Estimation" .


###  https://cdm.ovh/rsm/pop/pop#ExtensiveQuality
pop:ExtensiveQuality rdf:type owl:Class ;
                     rdfs:subClassOf pop:AssertedQuality ;
                     owl:disjointWith pop:IntensiveQuality ;
                     rdfs:label "Extensive quality"@en .


###  https://cdm.ovh/rsm/pop/pop#IntensiveQuality
pop:IntensiveQuality rdf:type owl:Class ;
                     rdfs:subClassOf pop:AssertedQuality ;
                     rdfs:label "Intensive quality"@en .


###  https://cdm.ovh/rsm/pop/pop#Interpolation
pop:Interpolation rdf:type owl:Class ;
                  rdfs:subClassOf pop:Estimation ;
                  rdfs:label "Interpolation"@en .


###  https://cdm.ovh/rsm/pop/pop#Observation
pop:Observation rdf:type owl:Class ;
                rdfs:subClassOf sosa:Observation ,
                                pop:AssertionGeneratingActivity ;
                rdfs:label "Observation"@en .


###  https://cdm.ovh/rsm/pop/pop#Prediction
pop:Prediction rdf:type owl:Class ;
               rdfs:subClassOf pop:AssertionGeneratingActivity ;
               rdfs:comment "The activity or process that produces predicted asserted qualities (not the predicted value itself)" ;
               rdfs:label "Prediction"@en .


###  https://cdm.ovh/rsm/pop/pop#Prescription
pop:Prescription rdf:type owl:Class ;
                 rdfs:subClassOf pop:AssertionGeneratingActivity ;
                 rdfs:label "Prescription"@en .


###  https://cdm.ovh/rsm/pop/pop#Specification
pop:Specification rdf:type owl:Class ;
                  rdfs:subClassOf pop:Prescription ;
                  rdfs:label "Specification"@en .


