        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-02-05</terms:created>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-03-11</terms:modified>
        <rdfs:comment xml:lang="en">Part of the phase info of a track that corresponds to the single selection of &apos;MIN=minimum&apos; or &apos;MAX=maximum&apos; to show whether the length is a minimum distance between the inner contact strips of the pantographs or a maximum distance between the outer contact strips of the pantographs. Multiple strings for this parameter are accepted.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">Phase info distance type</rdfs:label>
        <ns1:term_status>stable</ns1:term_status>
        <skos:scopeNote xml:lang="en"> The phase info is the indication of required several information on phase separation.</skos:scopeNote>
    </owl:DatatypeProperty>
    


