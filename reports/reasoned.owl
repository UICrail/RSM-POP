        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-02-20</terms:created>
        <rdfs:comment xml:lang="en">Link between the running track and the HABD, covering the RINF parameters 1.1.1.1.7.(5-9)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">hot axle box detector (HABD)</rdfs:label>
