        <rinfIndex>1.2.2.0.5</rinfIndex>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-10-31</terms:created>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">Tunnel</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://data.europa.eu/949/tunnelIdentification -->

    <owl:DatatypeProperty rdf:about="http://data.europa.eu/949/tunnelIdentification">
