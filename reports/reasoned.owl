        <ns1:term_status>stable</ns1:term_status>
        <skos:scopeNote xml:lang="en">Selected value shall answer the question whether any other system than ETCS exists on the respective track. The list of possible values is in line with ERA/TD/2011-09/INT, Table 3.</skos:scopeNote>
