        <applicable>Y/N</applicable>
        <legalDeadline xml:lang="en">In accordance with Implementing Decision 2014/880/EU and by 16 March 2019 at the latest</legalDeadline>
        <rinfIndex>1.2.0.0.0.6</rinfIndex>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/Kilometer"/>
        <tsiOPEAppendixD2Index>2.2.2</tsiOPEAppendixD2Index>
        <unitOfMeasure rdf:resource="http://qudt.org/vocab/unit/KiloM"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2021-01-29</terms:created>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2021-01-29</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-09-19</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-10-24</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-01-30</terms:modified>
        <terms:source rdf:resource="http://data.europa.eu/eli/reg_impl/2019/773/oj"/>
        <rdfs:comment xml:lang="en">Kilometer number of the kilometric post related to line identification defining the location of an infrastructure element.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">kilometer number</rdfs:label>
        <ns1:term_status>stable</ns1:term_status>
        <skos:altLabel xml:lang="en">Railway location of Operational point</skos:altLabel>
        <skos:scopeNote xml:lang="en">For walkways: Value provided in Kilometric point of the start of the walkway and the length in m. Repeatable values for each location.
For rescue points: Value provided in Kilometric point of the start of the point of evacuation and rescue point and the length in m. Repeatable values for each location.
For signals: Relative position to the line identified under parameter 1.1.0.0.0.2, given in km ([reference point, via era:referent] / [NNN.NNN] ).</skos:scopeNote>
    </owl:DatatypeProperty>
    


