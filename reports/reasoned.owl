    <!-- http://data.europa.eu/949/oclType -->

    <owl:DatatypeProperty rdf:about="http://data.europa.eu/949/oclType">
        <rdfs:subPropertyOf rdf:resource="http://data.europa.eu/949/vehicleTypeTechnicalDataCharacteristic"/>
        <rdfs:domain rdf:resource="http://data.europa.eu/949/VehicleTypeConfigParameterSet"/>
        <rdfs:range>
            <rdfs:Datatype>
                <owl:oneOf>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                        <rdf:first>A</rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                <rdf:first>B</rdf:first>
                                <rdf:rest>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                        <rdf:first>C</rdf:first>
                                        <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                                    </rdf:Description>
                                </rdf:rest>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </owl:oneOf>
            </rdfs:Datatype>
        </rdfs:range>
        <eratvIndex>4.10.9</eratvIndex>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2020-08-25</terms:created>
        <terms:isRequiredBy rdf:resource="http://data.europa.eu/eli/dec_impl/2011/665/oj"/>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2020-10-03</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-02-24</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-03-12</terms:modified>
        <rdfs:comment xml:lang="en">Type of OCL used for the test of current collection performance (to be indicated for each energy supply system the vehicle is equipped for) (only if number of raised pantographs is more than 1).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">Ocl type during current collection performance test</rdfs:label>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
        <ns1:term_status>archaic</ns1:term_status>
        <skos:editorialNote xml:lang="en">Given only present for initial types only, implemented without a Concept Scheme</skos:editorialNote>
        <skos:scopeNote xml:lang="en">The parameter is not applicable if `era:numberOfPantographsInContactWithOCL` &lt; 2.

The parameter must have as domain a VehicleTypeConfigParameterSet, of which the VehicleTypeConfiguration at least contains one EnergySystem,
from the ones recorded under `era:energySupplySystem`. Further, all of the ENE supply systems mentioned under that parameter
must have a value for this parameter `era:oclType`.</skos:scopeNote>
    </owl:DatatypeProperty>
    


