            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://data.europa.eu/949/CommonCharacteristicsSubset"/>
                    <rdf:Description rdf:about="http://data.europa.eu/949/RunningTrack"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://data.europa.eu/949/ETCS"/>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/Etcs"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2021-08-07</terms:created>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2021-09-12</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-08-13</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-09-19</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-02-28</terms:modified>
        <rdfs:comment xml:lang="en">European Train Control System (ETCS) application level supported by the track side equipment.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">TSI compliant train protection system (ETCS)</rdfs:label>
        <ns1:term_status>stable</ns1:term_status>
        <skos:scopeNote xml:lang="en">It can be repeated as many times as the number of different ETCS levels are present.

For RDF data provision:
The value of this property is an instance of the era:ETCS, which has as properties the parameters 1.1.1.3.2.1 and 1.1.1.3.2.2.

For RINF XML data sets:
As long as the data provision through XML data sets is allowed, this property is the equivalent of the &quot;Set&quot; attribute, grouping parameters 1.1.1.3.2.1 and 1.1.1.3.2.2.</skos:scopeNote>
    </owl:ObjectProperty>
    


