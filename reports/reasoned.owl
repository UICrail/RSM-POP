        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/NSAOrganisationIsFromRUShape-SCA"/>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/NSAOrganisationIsFromRUShape-SCB"/>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/RailwayUndertakingIsFromRUShape-SCA"/>
