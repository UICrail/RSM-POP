    <!-- http://data.europa.eu/949/conditionsSwitchTrainProtectionSystems -->

    <owl:DatatypeProperty rdf:about="http://data.europa.eu/949/conditionsSwitchTrainProtectionSystems">
        <rdfs:subPropertyOf rdf:resource="http://data.europa.eu/949/transitionsBetweenSystemsDataParameter"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://data.europa.eu/949/CommonCharacteristicsSubset"/>
                    <rdf:Description rdf:about="http://data.europa.eu/949/RunningTrack"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <XMLName>CTS_SwitchProtectControlWarnCondition</XMLName>
        <applicable>Y/N/NYA</applicable>
        <dependencyNote xml:lang="en">Applicable when at least two different protection, control and warning systems exist.</dependencyNote>
        <formatNote>NNN</formatNote>
        <legalDeadline xml:lang="en">12 months after publication of Article 7 Guide</legalDeadline>
