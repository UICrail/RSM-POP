        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-03-11</terms:modified>
        <terms:replaces rdf:resource="http://data.europa.eu/949/lineNationalId"/>
        <terms:replaces rdf:resource="http://data.europa.eu/949/lineReference"/>
        <rdfs:comment xml:lang="en">Indicates a relationship with a national railway line at a specific kilometer point.
For a Section of Line: unique line identification or unique line number within Member State.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">national line identification</rdfs:label>
        <ns1:term_status>stable</ns1:term_status>
        <skos:scopeNote xml:lang="en">Each SoL can belong to only one national line.

In case when SoL is the track connecting between OPs within big node (resulting from division of big station into several smaller) the line can be identified using the name of this track.</skos:scopeNote>
    </owl:ObjectProperty>
    


