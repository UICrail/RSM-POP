    <!-- http://data.europa.eu/949/lengthOfPlatform -->

    <owl:DatatypeProperty rdf:about="http://data.europa.eu/949/lengthOfPlatform">
        <rdfs:subPropertyOf rdf:resource="http://data.europa.eu/949/length"/>
        <rdfs:subPropertyOf rdf:resource="http://data.europa.eu/949/platformDataParameter"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://data.europa.eu/949/PlatformEdge"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <XMLName>IPL_Length</XMLName>
        <applicable>Y/N</applicable>
        <formatNote>NNNN</formatNote>
        <legalDeadline xml:lang="en">In accordance with Implementing Decision 2014/880/EU and by 16 March 2019 at the latest</legalDeadline>
        <rinfIndex>1.2.1.0.6.4</rinfIndex>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/LengthP"/>
        <tsiOPEAppendixD2Index>2.3.6</tsiOPEAppendixD2Index>
        <tsiOPEAppendixD2Index>3.2.3</tsiOPEAppendixD2Index>
        <unitOfMeasure rdf:resource="http://qudt.org/vocab/unit/M"/>
        <usedInRCCCalculations rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</usedInRCCCalculations>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-05-16</terms:created>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-09-19</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-03-11</terms:modified>
        <terms:source rdf:resource="http://data.europa.eu/eli/reg/2014/1299/2023-09-28"/>
        <terms:source rdf:resource="http://data.europa.eu/eli/reg_impl/2019/773/oj"/>
        <rdfs:comment xml:lang="en">The maximum continuous length (expressed in metres) of that part of platform in front of which a train is intended to remain stationary in normal operating conditions for passengers to board and alight from the train, making appropriate allowance for stopping tolerances.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">Usable length of platform</rdfs:label>
        <rdfs:seeAlso>INF TSI: 4.2.1, 4.2.9.1
OPE TSI: 4.2.2.5.2, 4.2.2.7.2</rdfs:seeAlso>
        <ns1:term_status>stable</ns1:term_status>
        <skos:scopeNote xml:lang="en">Platform dimensions are always related to one neighbouring track at a time.
So, if two tracks are along a platform, this platform should be divided into two RINF platforms to have precise description of each.</skos:scopeNote>
    </owl:DatatypeProperty>
    


