        <terms:source rdf:resource="http://data.europa.eu/eli/reg_impl/2023/1695/oj"/>
        <rdfs:comment xml:lang="en">Indication whether a switch over between different radio systems and no communication system whilst running exists.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">Existence of switch over between different radio systems</rdfs:label>
        <ns1:term_status>stable</ns1:term_status>
        <skos:scopeNote xml:lang="en">Switch over between different radio systems and no communication system whilst running. Installation depends on local conditions.

The &quot;Indication if other radio systems in normal operation are installed line-side&quot; is given in parameter 1.1.1.3.6.1 / SOL Track Parameter CRS_Installed</skos:scopeNote>
    </owl:DatatypeProperty>
    


