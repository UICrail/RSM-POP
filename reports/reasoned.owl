    <!-- http://data.europa.eu/949/conditionalRegenerativeBrake -->

    <owl:ObjectProperty rdf:about="http://data.europa.eu/949/conditionalRegenerativeBrake">
        <rdfs:subPropertyOf rdf:resource="http://data.europa.eu/949/trackObjParameter"/>
