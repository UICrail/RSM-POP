    <!-- http://data.europa.eu/949/etcsNationalPacket44Function -->

    <owl:ObjectProperty rdf:about="http://data.europa.eu/949/etcsNationalPacket44Function">
        <rdfs:subPropertyOf rdf:resource="http://data.europa.eu/949/tsiCompliantTrainProtectionSystemObjParameter"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://data.europa.eu/949/CommonCharacteristicsSubset"/>
