    </owl:DatatypeProperty>
    


    <!-- http://data.europa.eu/949/umax2 -->

    <owl:DatatypeProperty rdf:about="http://data.europa.eu/949/umax2">
        <rdfs:subPropertyOf rdf:resource="http://data.europa.eu/949/contactLineSystemDataParameter"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://data.europa.eu/949/ContactLineSystem"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <XMLName>ECS_Umax2</XMLName>
        <applicable>Y/N</applicable>
        <dependencyNote xml:lang="en">When `not electrified` is chosen in parameter 1.1.1.2.2.1.1, then this parameter is not applicable.</dependencyNote>
        <legalDeadline xml:lang="en">16 January 2020</legalDeadline>
        <rinfIndex>1.1.1.2.2.1.3</rinfIndex>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/Umax2"/>
        <unitOfMeasure rdf:resource="http://qudt.org/vocab/unit/V"/>
        <usedInRCCCalculations rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</usedInRCCCalculations>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2020-08-24</terms:created>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-01-08</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-09-25</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-02-28</terms:modified>
        <terms:relation rdf:resource="http://data.europa.eu/949/contactLineSystemType"/>
        <rdfs:comment xml:lang="en">Highest non-permanent voltage (Umax2) for France on lines not compliant with values defined in the EN50163:2004+A1:2007+A2:2020+A3:2022</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">Umax2 for the French network</rdfs:label>
        <rdfs:seeAlso xml:lang="en">ENE TSI: 4.2.4.1</rdfs:seeAlso>
        <ns1:term_status>stable</ns1:term_status>
        <skos:scopeNote xml:lang="en">Specific for the French network. It may concern DC 1.5kV and AC 25kV.

          For RINF XML data sets:
As long as the data provision through XML data sets is allowed, an XML attribute called “Set” will be used to link the value of this parameter to the parameter 1.1.1.2.2.1.1 / ECS_SystemType</skos:scopeNote>
    </owl:DatatypeProperty>
    


    <!-- http://data.europa.eu/949/uopid -->

    <owl:DatatypeProperty rdf:about="http://data.europa.eu/949/uopid">
        <rdfs:subPropertyOf rdf:resource="http://data.europa.eu/949/opGenericDataParameter"/>
        <rdfs:subPropertyOf rdf:resource="http://purl.org/dc/terms/identifier"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://data.europa.eu/949/OperationalPoint"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <XMLName>UniqueOPID</XMLName>
        <applicable>Y</applicable>
        <formatNote>CCAAAAAAAAAA
The first part  CC  is the country code in two-letter system of ISO.
The second part is alphanumeric OP code within the MS.
For example, an OP code could be current abbreviation of name used in route books.
In case of borders point, the code is to be selected in the corresponding list in annex 5.1</formatNote>
        <legalDeadline xml:lang="en">In accordance with Implementing Decision 2014/880/EU and by 16 March 2019 at the latest</legalDeadline>
        <rinfIndex>1.2.0.0.0.2</rinfIndex>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/BorderPointUopidPrefix"/>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/BorderPointValidCode"/>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/UopidP"/>
        <tsiOPEAppendixD2Index>2.2.2</tsiOPEAppendixD2Index>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2020-07-29</terms:created>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-01-08</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-09-19</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-02-24</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-03-11</terms:modified>
        <terms:source rdf:resource="http://data.europa.eu/eli/reg_impl/2019/773/oj"/>
        <rdfs:comment xml:lang="en">Code composed of country code and alphanumeric operational point code.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">Unique OP ID</rdfs:label>
        <rdfs:seeAlso>ISO 3166-1 alpha 2</rdfs:seeAlso>
        <ns1:term_status>stable</ns1:term_status>
        <skos:scopeNote xml:lang="en">Explanation on data presentation: The first two characters represent the country code in two-letter system of ISO.
The second part  AAAAAAAAAA  is maximum 10 Characters String corresponding to OP code within the MS.
&apos;LUAB4&apos; or &apos;LUAB46TH-G&apos; or &apos;LUAB4/-_ERT7&apos; are accepted by the validation process.
In case of  borders point , the code is to be selected in the corresponding list in annex 5.1 (this first part  AA  is EU. The second part is  AAAAAAAAAA ). Any OP ID that is not referenced in the annex 5.1 will not be accepted by the validation process.
In case of  domestic borders point , the code will be selected in the corresponding list in annex 5.2 that will be developed later.
Any OP ID that is not referenced in the annex 5.1 will not be accepted by the validation process.
The provided OP ID must be unique within each Member State. The validation has to be made nationally by NRE. The exceptions are  Border point  and  domestic border point  that must be referenced in annex 5.1.</skos:scopeNote>
    </owl:DatatypeProperty>
    


    <!-- http://data.europa.eu/949/usesGroup555 -->

    <owl:DatatypeProperty rdf:about="http://data.europa.eu/949/usesGroup555">
        <rdfs:subPropertyOf rdf:resource="http://data.europa.eu/949/tsiCompliantRadioDataParameter"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://data.europa.eu/949/CommonCharacteristicsSubset"/>
                    <rdf:Description rdf:about="http://data.europa.eu/949/RunningTrack"/>
                    <rdf:Description rdf:about="http://data.europa.eu/949/VehicleType"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <XMLName>CRG_Needof555</XMLName>
        <applicable>Y/N/NYA</applicable>
        <dependencyNote xml:lang="en">GSM-R and ETCS L2 must be installed for this parameter to be applicable.</dependencyNote>
        <eratvIndex>4.13.2.12</eratvIndex>
        <legalDeadline xml:lang="en">12 months after publication of Article 7 Guide for OP tracks</legalDeadline>
        <legalDeadline xml:lang="en">16 January 2020</legalDeadline>
        <rinfIndex>1.1.1.3.3.4</rinfIndex>
        <rinfIndex>1.2.1.1.2.4</rinfIndex>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/eratv/shapes/UsesGroup555"/>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/UsesGroup555"/>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/UsesGroup555Applicability"/>
        <usedInRCCCalculations rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</usedInRCCCalculations>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2020-08-31</terms:created>
        <terms:isRequiredBy rdf:resource="http://data.europa.eu/eli/dec_impl/2011/665/2019-06-16"/>
        <terms:isRequiredBy rdf:resource="http://data.europa.eu/eli/dec_impl/2011/665/2021-05-18"/>
        <terms:isRequiredBy rdf:resource="http://data.europa.eu/eli/dec_impl/2011/665/2023-09-08"/>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2021-09-12</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-04-18</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-02-26</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-03-04</terms:modified>
        <terms:relation rdf:resource="http://data.europa.eu/949/etcsLevelType"/>
        <rdfs:comment xml:lang="en">Indication if group 555 is used trackside or whether onboard has Voice SIM Card support for Group ID 555.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">GSM-R use of group 555</rdfs:label>
        <ns1:term_status>stable</ns1:term_status>
        <skos:scopeNote xml:lang="en">Sections of EIRENE not covered by references in TSI. GSM-R (parameter 1.1.1.3.3.1) and ETCS L2 (parameter 1.1.1.3.2.1) must be installed for this parameter to be applicable.</skos:scopeNote>
    </owl:DatatypeProperty>
    


    <!-- http://data.europa.eu/949/vNvallowovtrp -->

    <owl:DatatypeProperty rdf:about="http://data.europa.eu/949/vNvallowovtrp">
        <rdfs:subPropertyOf rdf:resource="http://data.europa.eu/949/etcsNationalValuesDataParameter"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://data.europa.eu/949/CommonCharacteristicsSubset"/>
                    <rdf:Description rdf:about="http://data.europa.eu/949/ETCS"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range>
            <rdfs:Datatype>
                <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#unsignedInt"/>
                <owl:withRestrictions rdf:parseType="Collection">
                    <rdf:Description>
                        <xsd:minInclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#unsignedInt">0</xsd:minInclusive>
                    </rdf:Description>
                    <rdf:Description>
                        <xsd:maxInclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#unsignedInt">600</xsd:maxInclusive>
                    </rdf:Description>
                </owl:withRestrictions>
            </rdfs:Datatype>
        </rdfs:range>
        <applicable>Y/N/NYA</applicable>
        <dependencyNote xml:lang="en">A value has to be provided when ETCS is present (a value is provided on 1.1.1.3.2.1).</dependencyNote>
        <formatNote>NNF, with N a decimal number (0 9), NNF must be divisible by 5, so F=(0|5), max. `600`</formatNote>
        <legalDeadline xml:lang="en">12 months after publication of Article 7 Guide</legalDeadline>
        <rinfIndex>1.1.1.3.2.16.3</rinfIndex>
        <rinfIndex>1.2.1.1.1.16.3</rinfIndex>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/VNvallowovtrp"/>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/VNvallowovtrpApplicability"/>
        <tsiOPEAppendixD3Index>1.5.3</tsiOPEAppendixD3Index>
        <unitOfMeasure rdf:resource="http://qudt.org/vocab/unit/KiloM-PER-HR"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-11-07</terms:created>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2023-03-14</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-09-19</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-05</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-02-27</terms:modified>
        <terms:relation rdf:resource="http://data.europa.eu/949/etcsLevelType"/>
        <terms:source rdf:resource="http://data.europa.eu/eli/reg_impl/2023/1695/oj"/>
        <rdfs:comment xml:lang="en">Speed limit allowing the driver to select the  override  function in km/h
According to the specification referenced in Appendix A-1, index [C]</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">V_NVALLOWOVTRP</rdfs:label>
        <rdfs:seeAlso rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://www.era.europa.eu/domains/technical-specifications-interoperability/control-command-and-signalling-tsi_en#oe-content-paragraph-1632</rdfs:seeAlso>
        <rdfs:seeAlso>TSI CCS (Subset-026, Chapter 7. 7.5.1.161)</rdfs:seeAlso>
        <ns1:term_status>stable</ns1:term_status>
        <skos:scopeNote xml:lang="en">Format: [NNF], with N a decimal number (0÷9), [NNF] must be divisible by 5, so F=(0|5), max. `600`.</skos:scopeNote>
    </owl:DatatypeProperty>
    


    <!-- http://data.europa.eu/949/vNvsupovtrp -->

    <owl:DatatypeProperty rdf:about="http://data.europa.eu/949/vNvsupovtrp">
        <rdfs:subPropertyOf rdf:resource="http://data.europa.eu/949/etcsNationalValuesDataParameter"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://data.europa.eu/949/CommonCharacteristicsSubset"/>
                    <rdf:Description rdf:about="http://data.europa.eu/949/ETCS"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range>
            <rdfs:Datatype>
                <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#unsignedInt"/>
                <owl:withRestrictions rdf:parseType="Collection">
                    <rdf:Description>
                        <xsd:minInclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#unsignedInt">0</xsd:minInclusive>
                    </rdf:Description>
                    <rdf:Description>
                        <xsd:maxInclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#unsignedInt">600</xsd:maxInclusive>
                    </rdf:Description>
                </owl:withRestrictions>
            </rdfs:Datatype>
        </rdfs:range>
        <applicable>Y/N/NYA</applicable>
        <dependencyNote xml:lang="en">A value has to be provided when ETCS is present (a value is provided on 1.1.1.3.2.1).</dependencyNote>
        <formatNote>NNF, with N a decimal number (0 9), NNF must be divisible by 5, so F=(0|5), max. `600`</formatNote>
        <legalDeadline xml:lang="en">12 months after publication of Article 7 Guide</legalDeadline>
        <legalDeadline xml:lang="en">12 months after publication of Article 7 Guide for OP tracks</legalDeadline>
        <rinfIndex>1.1.1.3.2.16.4</rinfIndex>
        <rinfIndex>1.2.1.1.1.16.4</rinfIndex>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/VNvsupovtrp"/>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/VNvsupovtrpApplicability"/>
        <tsiOPEAppendixD3Index>1.5.4</tsiOPEAppendixD3Index>
        <unitOfMeasure rdf:resource="http://qudt.org/vocab/unit/KiloM-PER-HR"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-11-07</terms:created>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2023-03-14</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-09-19</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-05</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-02-27</terms:modified>
        <terms:relation rdf:resource="http://data.europa.eu/949/etcsLevelType"/>
        <terms:source rdf:resource="http://data.europa.eu/eli/reg_impl/2023/1695/oj"/>
        <rdfs:comment xml:lang="en">Override speed limit to be supervised when the &quot;override&quot; function is active in km/h.
According to the specification referenced in Appendix A-1, index [C]</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">V_NVSUPOVTRP</rdfs:label>
        <rdfs:seeAlso rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://www.era.europa.eu/domains/technical-specifications-interoperability/control-command-and-signalling-tsi_en#oe-content-paragraph-1632</rdfs:seeAlso>
        <rdfs:seeAlso>TSI CCS (Subset-026, chapter 7. 7.5.1.163 V_NVSUPOVTRP)</rdfs:seeAlso>
        <ns1:term_status>stable</ns1:term_status>
        <skos:scopeNote xml:lang="en">Format: [NNF], with N a decimal number (0÷9), [NNF] is divisible by 5 so F=(0|5), max. `600`.</skos:scopeNote>
    </owl:DatatypeProperty>
    


