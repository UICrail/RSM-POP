        <terms:source rdf:resource="http://data.europa.eu/eli/reg/2014/1299/2023-09-28#tocId30"/>
        <rdfs:comment xml:lang="en">For sections of line with a maximum permitted speed of 200 km/h or more. Information regarding the procedure to be used to perform the dynamic compatibility check.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">Compliance of structures with the High Speed Load Model (HSLM)</rdfs:label>
        <rdfs:seeAlso>Annex D1 OPE TSI
INF TSI: 4.2.7.1.2(2)</rdfs:seeAlso>
        <ns1:term_status>stable</ns1:term_status>
        <skos:scopeNote xml:lang="en">(TSI INF 4.2.7.1.2(2)) Applicable if the maximum permitted speed of the running track is more than 200km/h and the structures within the section of line are all compatible with the High Speed Load Model (HSLM); information regarding the procedure to be used to perform the dynamic compatibility check shall be provided as well.</skos:scopeNote>
    </owl:DatatypeProperty>
    


