        <terms:isRequiredBy rdf:resource="http://data.europa.eu/eli/dec_impl/2011/665/2023-09-08"/>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-01-29</terms:modified>
        <terms:source rdf:resource="http://data.europa.eu/eli/dir/2016/797/oj"/>
        <rdfs:comment xml:lang="en">(32) ‘area of use of a vehicle’ means a network or networks within a Member State or a group of Member States in which a vehicle is intended to be used;</rdfs:comment>
