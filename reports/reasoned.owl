        <XMLName>OPTrackTunnelIdentification</XMLName>
        <XMLName>SOLTunnelIdentification</XMLName>
        <applicable>Y</applicable>
        <legalDeadline xml:lang="en">In accordance with Implementing Decision 2014/880/EU and by 16 March 2019 at the latest</legalDeadline>
        <rinfIndex>1.1.1.1.8.2</rinfIndex>
        <rinfIndex>1.2.1.0.5.2</rinfIndex>
        <rinfIndex>1.2.2.0.5.2</rinfIndex>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/TunnelIdentification"/>
        <tsiOPEAppendixD2Index>3.2.3</tsiOPEAppendixD2Index>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2021-08-03</terms:created>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2021-09-13</terms:modified>
