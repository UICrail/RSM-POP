    <!-- http://data.europa.eu/949/hotAxleBoxDetectorDirection -->

    <owl:ObjectProperty rdf:about="http://data.europa.eu/949/hotAxleBoxDetectorDirection">
        <rdfs:subPropertyOf rdf:resource="http://data.europa.eu/949/healthSafetyAndEnvironmentObjParameter"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://data.europa.eu/949/HABD"/>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <XMLName>IHS_HABDDirection</XMLName>
        <applicable>Y/N</applicable>
        <dependencyNote xml:lang="en">Mandatory if the HABD is not TSI compliant (the value of parameter 1.1.1.1.7.5 (Trackside HABD TSI compliant) is &apos;False&apos;)</dependencyNote>
        <inSkosConceptScheme rdf:resource="http://data.europa.eu/949/concepts/hot-axle-box-detector-direction/HotAxleBoxDetectorDirections"/>
        <legalDeadline xml:lang="en">16 January 2020</legalDeadline>
        <rinfIndex>1.1.1.1.7.9</rinfIndex>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/HotAxleBoxDetectorDirection"/>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/HotAxleBoxDetectorDirectionApplicability"/>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/HotAxleBoxDetectorDirectionCountryApplicability"/>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/HotAxleBoxDetectorDirectionSKOS"/>
        <usedInRCCCalculations rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</usedInRCCCalculations>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-07-08</terms:created>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-01-08</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-02-20</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-02-28</terms:modified>
        <rdfs:comment xml:lang="en">Direction of measurement of trackside HABD, specific for the French Italian and Swedish networks.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">Direction of measurement of trackside HABD</rdfs:label>
        <ns1:term_status>stable</ns1:term_status>
        <skos:changeNote xml:lang="en">This property was previously a datatype property with domain Track and range string. As its values are a list of three predefined values, it is now a SKOS.</skos:changeNote>
        <skos:scopeNote xml:lang="en">Specific for the French Italian and Swedish networks.
Applicable if trackside HABD is not TSI compliant, direction of measurement of trackside hot axle box detector.
If the direction of measurement is:
-	the same as the direction defined by the start and end of the SoL: (N)
-	the opposite to the direction defined by the start and end of the SoL: (O)
-	both directions: (B)</skos:scopeNote>
    </owl:ObjectProperty>
    


