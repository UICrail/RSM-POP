    <!-- http://data.europa.eu/949/vehicleKeeperMarking -->

    <owl:ObjectProperty rdf:about="http://data.europa.eu/949/vehicleKeeperMarking">
        <rdfs:subPropertyOf rdf:resource="http://data.europa.eu/949/vehicleTechnicalObjCharacteristic"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://data.europa.eu/949/Vehicle"/>
