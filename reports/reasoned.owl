    <!-- http://data.europa.eu/949/minVehicleImpedance -->

    <owl:ObjectProperty rdf:about="http://data.europa.eu/949/minVehicleImpedance">
        <rdfs:subPropertyOf rdf:resource="http://data.europa.eu/949/trainDetectionSystemBasedFrequencyBandsObjParameter"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://data.europa.eu/949/TrainDetectionSystem"/>
                    <rdf:Description rdf:about="http://data.europa.eu/949/VehicleTypeConfigParameterSet"/>
                </owl:unionOf>
