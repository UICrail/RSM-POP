        <evrIndex>11.9.1</evrIndex>
        <inSkosConceptScheme rdf:resource="http://data.europa.eu/949/concepts/etcs-equipment-on-board-level/ETCSEquipmentLevels"/>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/EtcsEquipmentOnBoardLevel"/>
