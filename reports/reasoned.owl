        <terms:source rdf:resource="http://data.europa.eu/eli/reg_impl/2023/1695/oj"/>
        <rdfs:comment xml:lang="en">Indication of existence of metal mass in the vicinity of the location, susceptible of perturbating the reading of balises by the on-board system.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">Big Metal Mass</rdfs:label>
        <ns1:term_status>stable</ns1:term_status>
        <skos:scopeNote xml:lang="en">According to the specification referenced in TSI CCS.</skos:scopeNote>
    </owl:DatatypeProperty>
    


