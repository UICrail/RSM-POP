    <!-- http://data.europa.eu/949/vehicleTypeNumber -->

    <owl:DatatypeProperty rdf:about="http://data.europa.eu/949/vehicleTypeNumber">
        <rdfs:subPropertyOf rdf:resource="http://data.europa.eu/949/vehicleTypeTechnicalDataCharacteristic"/>
        <rdfs:domain rdf:resource="http://data.europa.eu/949/VehicleType"/>
