    <!-- http://data.europa.eu/949/etcsDegradedSituation -->

    <owl:ObjectProperty rdf:about="http://data.europa.eu/949/etcsDegradedSituation">
        <rdfs:subPropertyOf rdf:resource="http://data.europa.eu/949/lineSideSystemDegradedSituationObjParameter"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://data.europa.eu/949/CommonCharacteristicsSubset"/>
                    <rdf:Description rdf:about="http://data.europa.eu/949/RunningTrack"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <XMLName>CLD_ETCSSituation</XMLName>
        <applicable>Y/N/NYA</applicable>
        <dependencyNote xml:lang="en">Mandatory when ETCS is present. </dependencyNote>
        <inSkosConceptScheme rdf:resource="http://data.europa.eu/949/concepts/etcs-situation/ETCSSituations"/>
        <legalDeadline xml:lang="en">12 months after publication of Article 7 Guide for OP tracks</legalDeadline>
        <legalDeadline xml:lang="en">In accordance with Implementing Decision 2014/880/EU and by 16 March 2019 at the latest</legalDeadline>
        <rinfIndex>1.1.1.3.10.1</rinfIndex>
        <rinfIndex>1.2.1.1.9.1</rinfIndex>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/EtcsDegradedSituation"/>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/EtcsDegradedSituationApplicability"/>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/EtcsDegradedSituationSKOS"/>
        <tsiOPEAppendixD2Index>3.4.1</tsiOPEAppendixD2Index>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2021-08-09</terms:created>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2021-09-12</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-04-18</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-09-19</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-03-04</terms:modified>
        <terms:relation rdf:resource="http://data.europa.eu/949/etcsLevelType"/>
        <terms:source rdf:resource="http://data.europa.eu/eli/reg_impl/2019/773/2023-09-28"/>
        <terms:source rdf:resource="http://data.europa.eu/eli/reg_impl/2023/1695/oj"/>
        <rdfs:comment xml:lang="en">ERTMS / ETCS application level for degraded situation related to the track side equipment.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">ETCS level for degraded situation</rdfs:label>
        <rdfs:seeAlso rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://eur-lex.europa.eu/eli/reg_impl/2019/773/oj</rdfs:seeAlso>
        <ns1:term_status>stable</ns1:term_status>
        <skos:example>Level 1 as a degraded mode for Level 2.</skos:example>
        <skos:scopeNote xml:lang="en">System for degraded situation.

In case of failure of the ETCS Level for normal operation, train movement can be supervised in another ETCS Level.

If parameter 1.1.1.3.2.1 is not used (no ETCS), no degradation is possible, so only &quot;none&quot; level is possible for degraded .
It assumed that the degraded level has to be lower than the actual operating level.
See also TSI OPE 4.2.3.6. Degraded operation.</skos:scopeNote>
    </owl:ObjectProperty>
    


    <!-- http://data.europa.eu/949/etcsEquipmentOnBoardLevel -->

    <owl:ObjectProperty rdf:about="http://data.europa.eu/949/etcsEquipmentOnBoardLevel">
