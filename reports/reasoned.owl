        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/MWS-CB-RoleShape"/>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/MWSHasRoleShape"/>
