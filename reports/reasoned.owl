     -->

    


    <!-- http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Entity -->

    <owl:Class rdf:about="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Entity">
        <rdfs:label xml:lang="en">Entity</rdfs:label>
    </owl:Class>
    


    <!-- http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#InformationObject -->

    <owl:Class rdf:about="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#InformationObject"/>
    


    <!-- http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Process -->

    <owl:Class rdf:about="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Process"/>
    


    <!-- http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Region -->

    <owl:Class rdf:about="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Region"/>
    


    <!-- http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#TimeInterval -->

    <owl:Class rdf:about="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#TimeInterval"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#Concept -->

    <owl:Class rdf:about="http://www.w3.org/2004/02/skos/core#Concept">
        <rdfs:comment xml:lang="en">possible concepts describing the effect of aggregation on the property value, in a concept scheme to be defined: maximum / minimum / product / logical AND / logical OR / list / undefined / weighted average / ...</rdfs:comment>
        <rdfs:label xml:lang="en">concept</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/ns/prov#Activity -->

    <owl:Class rdf:about="http://www.w3.org/ns/prov#Activity"/>
    


    <!-- http://www.w3.org/ns/sosa/Observation -->

    <owl:Class rdf:about="http://www.w3.org/ns/sosa/Observation"/>
    


    <!-- https://cdm.ovh/rsm/pop/pop#AssertedQuality -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/pop/pop#AssertedQuality">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#InformationObject"/>
        <rdfs:comment xml:lang="en">The externally defined property (NOT: PROPERTY VALUE) that AssertedQuality refers to shall be indicated using pop:aboutProperty, which is an owl:AnnotationProperty. pop:aboutProperty can target any rdf resource, such as a class, an object property, a data property, as long as that resource unambiguously defines what property is meant (from a domain point of view).</rdfs:comment>
        <rdfs:label xml:lang="en">Asserted quality</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/pop/pop#AssertedTimeInterval -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/pop/pop#AssertedTimeInterval">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#TimeInterval"/>
        <rdfs:comment xml:lang="en">a sosa:resultTime is equivalent to a degenerated pop:AssertedInterval. In general, if the observation period is an interval, it will result in an AssertedInterval ending at the resultTime.</rdfs:comment>
        <rdfs:label xml:lang="en">Asserted time interval</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/pop/pop#AssertedValue -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/pop/pop#AssertedValue">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Region"/>
        <rdfs:comment xml:lang="en">The value (quality or quantity) and its uncertainty or tolerance, in most generic form.</rdfs:comment>
        <rdfs:label>Asserted value</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/pop/pop#AssertionGeneratingActivity -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/pop/pop#AssertionGeneratingActivity">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Process"/>
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Activity"/>
        <rdfs:label>Assertion-generating activity</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/pop/pop#Correction -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/pop/pop#Correction">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/pop/pop#AssertionGeneratingActivity"/>
        <rdfs:label xml:lang="en">Correction</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/pop/pop#Estimation -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/pop/pop#Estimation">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/pop/pop#AssertionGeneratingActivity"/>
        <rdfs:comment xml:lang="en">another source kind that may involve data gap-filling, intra- or extrapolation, filtering, reconciliation, and assorted decision points. Usually resting on multiple sources.</rdfs:comment>
        <rdfs:label>Estimation</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/pop/pop#ExtensiveQuality -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/pop/pop#ExtensiveQuality">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/pop/pop#AssertedQuality"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/rsm/pop/pop#IntensiveQuality"/>
        <rdfs:label xml:lang="en">Extensive quality</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/pop/pop#IntensiveQuality -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/pop/pop#IntensiveQuality">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/pop/pop#AssertedQuality"/>
        <rdfs:label xml:lang="en">Intensive quality</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/pop/pop#Interpolation -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/pop/pop#Interpolation">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/pop/pop#Estimation"/>
        <rdfs:label xml:lang="en">Interpolation</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/pop/pop#Observation -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/pop/pop#Observation">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/sosa/Observation"/>
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/pop/pop#AssertionGeneratingActivity"/>
        <rdfs:label xml:lang="en">Observation</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/pop/pop#Prediction -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/pop/pop#Prediction">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/pop/pop#AssertionGeneratingActivity"/>
        <rdfs:comment>The activity or process that produces predicted asserted qualities (not the predicted value itself)</rdfs:comment>
        <rdfs:label xml:lang="en">Prediction</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/pop/pop#Prescription -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/pop/pop#Prescription">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/pop/pop#AssertionGeneratingActivity"/>
        <rdfs:label xml:lang="en">Prescription</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/pop/pop#Specification -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/pop/pop#Specification">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/pop/pop#Prescription"/>
        <rdfs:label xml:lang="en">Specification</rdfs:label>
    </owl:Class>
</rdf:RDF>



