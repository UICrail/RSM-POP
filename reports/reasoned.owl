    <!-- http://purl.org/dc/elements/1.1/date -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/date"/>
    


    <!-- http://purl.org/dc/elements/1.1/description -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/description"/>
    


    <!-- http://purl.org/dc/elements/1.1/license -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/license"/>
    


    <!-- http://purl.org/dc/elements/1.1/title -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/title"/>
    


    <!-- https://cdm.ovh/rsm/pop/pop#aboutProperty -->

    <owl:AnnotationProperty rdf:about="https://cdm.ovh/rsm/pop/pop#aboutProperty">
        <rdfs:comment xml:lang="en">References the external property (rdf:Property, owl:ObjectProperty, owl:DatatypeProperty, reified property, ...) that an AssertedQuality is about. Ignored by OWL reasoners; provides semantic context only.</rdfs:comment>
        <rdfs:label xml:lang="en">about property</rdfs:label>
    </owl:AnnotationProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.w3.org/2001/XMLSchema#dateTime -->

    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#dateTime"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://cdm.ovh/rsm/pop/pop#aboutEntity -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/pop/pop#aboutEntity">
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/pop/pop#AssertedQuality"/>
        <rdfs:range rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Entity"/>
        <rdfs:label xml:lang="en">about entity</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/pop/pop#aggregationRule -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/pop/pop#aggregationRule">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/pop/pop#IntensiveQuality"/>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:label xml:lang="en">aggregation rule</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/pop/pop#assertedBy -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/pop/pop#assertedBy">
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/pop/pop#AssertedQuality"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/pop/pop#AssertionGeneratingActivity"/>
        <rdfs:label>asserted by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/pop/pop#boundariesNode -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/pop/pop#boundariesNode">
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/pop/pop#AssertedValue"/>
        <rdfs:comment xml:lang="en">Can be expressed as an interval (hence &quot;boundaries&quot;), or a distribution, a confidence interval, etc.</rdfs:comment>
        <rdfs:label xml:lang="en">boundaries node</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/pop/pop#hasAssertedValue -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/pop/pop#hasAssertedValue">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/pop/pop#AssertedQuality"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/pop/pop#AssertedValue"/>
        <rdfs:label xml:lang="en">has asserted value</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/pop/pop#valueNode -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/pop/pop#valueNode">
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/pop/pop#AssertedValue"/>
        <rdfs:comment xml:lang="en">valueNode points to any resource (possibly an IRI, a string, a blank node...) holding the value of a property. It may be the original value provided by an RDF data source. Data type (if applicable) and data constraints are entirely the responsibility of the source.</rdfs:comment>
        <rdfs:label xml:lang="en">value node</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://cdm.ovh/rsm/pop/pop#hasSimpleResult -->

    <owl:DatatypeProperty rdf:about="https://cdm.ovh/rsm/pop/pop#hasSimpleResult">
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/pop/pop#AssertedQuality"/>
        <rdfs:comment xml:lang="en">Generalization of sosa:hasSimpleResult</rdfs:comment>
        <rdfs:label>has simple result</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://cdm.ovh/rsm/pop/pop#resultTime -->

    <owl:DatatypeProperty rdf:about="https://cdm.ovh/rsm/pop/pop#resultTime">
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/pop/pop#AssertedQuality"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="en">generalisation of sosa:resultTime</rdfs:comment>
        <rdfs:label xml:lang="en">result time</rdfs:label>
    </owl:DatatypeProperty>
    


