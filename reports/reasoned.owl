    <!-- http://data.europa.eu/949/hasOCLChargeableTractionStorage -->

    <owl:DatatypeProperty rdf:about="http://data.europa.eu/949/hasOCLChargeableTractionStorage">
        <rdfs:subPropertyOf rdf:resource="http://data.europa.eu/949/vehicleTypeTechnicalDataCharacteristic"/>
        <rdfs:domain rdf:resource="http://data.europa.eu/949/VehicleTypeConfigParameterSet"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <eratvIndex>4.10.16</eratvIndex>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/HasOCLChargeableTractionStorage"/>
