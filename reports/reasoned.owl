        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
        <ns1:term_status>stable</ns1:term_status>
        <skos:editorialNote xml:lang="en">Deprecated because of replacement by a class and three integer properties The reason is that the property is composed of three values: [N] is number of pantographs; [NNN] is minimum distance between pantographs, in metres; [NNN] is the speed considered in km/h.</skos:editorialNote>
    </owl:DatatypeProperty>
    


