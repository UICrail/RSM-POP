    <!-- http://data.europa.eu/949/opEnd -->

    <owl:ObjectProperty rdf:about="http://data.europa.eu/949/opEnd">
        <rdfs:subPropertyOf rdf:resource="http://data.europa.eu/949/solGenericObjParameter"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://data.europa.eu/949/SectionOfLine"/>
        <rdfs:range rdf:resource="http://data.europa.eu/949/OperationalPoint"/>
        <XMLName>SOLOPEnd</XMLName>
        <applicable>Y</applicable>
        <legalDeadline xml:lang="en">In accordance with Implementing Decision 2014/880/EU and by 16 March 2019 at the latest</legalDeadline>
        <rinfIndex>1.1.0.0.0.4</rinfIndex>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/OpEnd"/>
        <tsiOPEAppendixD2Index>3.1.2</tsiOPEAppendixD2Index>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2021-09-09</terms:created>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-01-08</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-09-19</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-03-11</terms:modified>
        <terms:source rdf:resource="http://data.europa.eu/eli/reg_impl/2019/773/oj"/>
        <rdfs:comment xml:lang="en">Operational point at the end of section of line (kilometres increasing from start OP to the end OP).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">Operational point at end of section of line</rdfs:label>
        <ns1:term_status>stable</ns1:term_status>
        <skos:scopeNote xml:lang="en">Each SoL may have only one end OP, and each OP has unique OP ID within the MS. The “uniqueOPID” is defined in parameter 1.2.0.0.0.2.
Each SoL has the principal direction of the traffic defined by increasing kilometres running from the start OP to the end OP.
That is why the end OP is always located at highest kilometre of the line within the SoL.
No validation will be performed by RINF application regarding which is the start and which the end OP. This requires IM&apos;s verification. </skos:scopeNote>
    </owl:ObjectProperty>
    


