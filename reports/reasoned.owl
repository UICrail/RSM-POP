    <!-- http://data.europa.eu/949/startLocation -->

    <owl:ObjectProperty rdf:about="http://data.europa.eu/949/startLocation">
        <rdfs:subPropertyOf rdf:resource="http://data.europa.eu/949/tunnelObjParameter"/>
        <rdfs:subPropertyOf rdf:resource="http://www.opengis.net/ont/geosparql#hasGeometry"/>
