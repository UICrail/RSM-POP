    <!-- http://data.europa.eu/949/publicNetworkRoaming -->

    <owl:DatatypeProperty rdf:about="http://data.europa.eu/949/publicNetworkRoaming">
        <rdfs:subPropertyOf rdf:resource="http://data.europa.eu/949/tsiCompliantRadioDataParameter"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://data.europa.eu/949/CommonCharacteristicsSubset"/>
                    <rdf:Description rdf:about="http://data.europa.eu/949/RunningTrack"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <XMLName>CRG_RoamingPublic</XMLName>
        <applicable>Y/N/NYA</applicable>
        <dependencyNote xml:lang="en">GSM-R must be installed for this parameter to be applicable</dependencyNote>
        <legalDeadline xml:lang="en">1 January 2021</legalDeadline>
        <legalDeadline xml:lang="en">12 months after publication of Article 7 Guide for OP tracks</legalDeadline>
        <rinfIndex>1.1.1.3.3.6</rinfIndex>
        <rinfIndex>1.2.1.1.2.6</rinfIndex>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/PublicNetworkRoaming"/>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/PublicNetworkRoamingApplicability"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2021-08-09</terms:created>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-01-08</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-03-04</terms:modified>
        <terms:relation rdf:resource="http://data.europa.eu/949/publicNetworkRoamingDetails"/>
        <rdfs:comment xml:lang="en">Existence of roaming to a public network.

                         In case of Y, provide the name of the public network(s) under parameter &quot;Details on GSM-R roaming to public networks&quot;.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">Existence of GSM-R roaming to public networks</rdfs:label>
        <ns1:term_status>stable</ns1:term_status>
        <skos:scopeNote xml:lang="en">Sections of EIRENE not covered by references in TSI.</skos:scopeNote>
    </owl:DatatypeProperty>
    


    <!-- http://data.europa.eu/949/publicNetworkRoamingDetails -->

    <owl:DatatypeProperty rdf:about="http://data.europa.eu/949/publicNetworkRoamingDetails">
        <rdfs:subPropertyOf rdf:resource="http://data.europa.eu/949/tsiCompliantRadioDataParameter"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://data.europa.eu/949/CommonCharacteristicsSubset"/>
                    <rdf:Description rdf:about="http://data.europa.eu/949/RunningTrack"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <XMLName>CRG_RoamingPublicDetails</XMLName>
        <applicable>Y/N/NYA</applicable>
        <dependencyNote xml:lang="en">Mandatory if GSM-R is installed and era:publicNetworkRoaming is &apos;true&apos;. Otherwise, it is not applicable.</dependencyNote>
        <legalDeadline xml:lang="en">1 January 2021</legalDeadline>
        <legalDeadline xml:lang="en">12 months after publication of Article 7 Guide for OP tracks</legalDeadline>
        <rinfIndex>1.1.1.3.3.7</rinfIndex>
        <rinfIndex>1.2.1.1.2.7</rinfIndex>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/PublicNetworkRoamingDetails"/>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/PublicNetworkRoamingDetailsApplicability"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2021-08-09</terms:created>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-01-08</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-04-18</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-03-04</terms:modified>
        <terms:relation rdf:resource="http://data.europa.eu/949/publicNetworkRoaming"/>
        <rdfs:comment xml:lang="en">If roaming to public networks is configured, please indicate to which networks, for which users and in which areas.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">Details on GSM-R roaming to public networks</rdfs:label>
        <ns1:term_status>stable</ns1:term_status>
        <skos:scopeNote xml:lang="en">List if any GSM-R functionality is not available when roaming to a public network (e.g. REC, Functional Addressing, Group Calls).
Please also add if there is any operational restriction for vehicles that cannot roam into any of the available public networks.</skos:scopeNote>
    </owl:DatatypeProperty>
    


    <!-- http://data.europa.eu/949/qNvsbtsmperm -->

    <owl:DatatypeProperty rdf:about="http://data.europa.eu/949/qNvsbtsmperm">
        <rdfs:subPropertyOf rdf:resource="http://data.europa.eu/949/etcsNationalValuesDataParameter"/>
