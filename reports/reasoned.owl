        <rdfs:label xml:lang="en">Vehicle impedance</rdfs:label>
        <rdfs:seeAlso rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://eur-lex.europa.eu/eli/reg_impl/2023/1695/oj</rdfs:seeAlso>
        <skos:scopeNote xml:lang="en">Compatibility with track circuits. A track circuit is only able to detect rolling stock if the impedance between rails does not exceed a certain value.</skos:scopeNote>
    </owl:ObjectProperty>
    


