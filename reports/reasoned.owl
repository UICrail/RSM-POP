    </owl:Class>
    


    <!-- http://www.w3.org/1999/02/22-rdf-syntax-ns#List -->

    <owl:Class rdf:about="http://www.w3.org/1999/02/22-rdf-syntax-ns#List">
        <rdfs:label xml:lang="en">List</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/2000/01/rdf-schema#Bag -->

    <owl:Class rdf:about="http://www.w3.org/2000/01/rdf-schema#Bag"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#Concept -->

    <owl:Class rdf:about="http://www.w3.org/2004/02/skos/core#Concept">
        <rdfs:label xml:lang="en">Concept</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/2006/time#DurationDescription -->

    <owl:Class rdf:about="http://www.w3.org/2006/time#DurationDescription"/>
    


    <!-- http://www.w3.org/2006/time#Instant -->

    <owl:Class rdf:about="http://www.w3.org/2006/time#Instant">
        <rdfs:label xml:lang="en">Time instant</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/2006/time#TemporalDuration -->

    <owl:Class rdf:about="http://www.w3.org/2006/time#TemporalDuration">
        <rdfs:label xml:lang="en">Temporal duration</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/2006/time#TemporalEntity -->

    <owl:Class rdf:about="http://www.w3.org/2006/time#TemporalEntity">
