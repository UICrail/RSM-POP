        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-02-27</terms:modified>
        <terms:relation rdf:resource="http://data.europa.eu/949/etcsLevelType"/>
        <terms:source rdf:resource="http://data.europa.eu/eli/reg_impl/2023/1695/oj"/>
        <rdfs:comment xml:lang="en">Indication whether infill is required to access the line for safety reasons.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">ETCS infill necessary for line access</rdfs:label>
        <rdfs:seeAlso>TSI CCS 7.2.9.1 &amp; 4.2.3</rdfs:seeAlso>
        <ns1:term_status>stable</ns1:term_status>
        <skos:scopeNote xml:lang="en">As indicated in CCS TSI section 7.2.9.1, an ETCS Level 1 trackside application may require that the on-board is equipped with the corresponding in-fill data transmission (Euroloop or radio)
                         if the release speed is set to zero for safety reasons.</skos:scopeNote>
    </owl:DatatypeProperty>
    


