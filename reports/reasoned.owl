    <!-- http://data.europa.eu/949/tenGISId -->

    <owl:DatatypeProperty rdf:about="http://data.europa.eu/949/tenGISId">
        <rdfs:subPropertyOf rdf:resource="http://data.europa.eu/949/performanceDataParameter"/>
