        <rdfs:comment xml:lang="en">Denoting the state of the certificate/declaration. Can be in one of the following: Amended, New, Suspended, Withdrawn.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">State</rdfs:label>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</owl:deprecated>
        <ns1:term_status>stable</ns1:term_status>
        <skos:editorialNote xml:lang="en">The state for CLD is being examined by NBRail, and will be reused for the other classes as well.</skos:editorialNote>
    </owl:ObjectProperty>
    


    <!-- http://data.europa.eu/949/subCategory -->

    <owl:ObjectProperty rdf:about="http://data.europa.eu/949/subCategory">
