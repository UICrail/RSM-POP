    <!-- http://data.europa.eu/949/certificate -->

    <owl:ObjectProperty rdf:about="http://data.europa.eu/949/certificate">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://data.europa.eu/949/VehicleType"/>
                    <rdf:Description rdf:about="http://data.europa.eu/949/VehicleTypeAuthorisationCase"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://w3id.org/vpa#EvidenceDocument"/>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/Certificate"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-06-15</terms:created>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-11-15</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-04-18</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-10-30</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-04-04</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-09-24</terms:modified>
        <rdfs:comment xml:lang="en">For this Vehicle Type (and its underlying authorisation cases),
- the type or design examination certificate (`era:CertificationLevelDocument`) described in the relevant verification module as issued by Notified Bodies, supporting the EC Declaration(s) of Verification for the subsystems in scope of the type&apos;s authorisation by an authorizing entity.
- a National certificate reference (`vpa:EvidenceDocument`)

Use only if no link can be made with the underlying authorisation and its presented certificates.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">Certificate, supporting the Vehicle Type&apos;s authorisation process.</rdfs:label>
        <ns1:term_status>stable</ns1:term_status>
        <skos:editorialNote xml:lang="en">The direct link between era:VehicleType(AuthorisationCase) and era:CertificationLevelDocument via this property is only allowed for VT&apos;s of which no authorisation process can be traced.</skos:editorialNote>
    </owl:ObjectProperty>
    


