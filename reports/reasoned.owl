        <ns1:term_status>stable</ns1:term_status>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:AnnotationProperty>
    


    <!-- http://data.europa.eu/949/tsiOPEAppendixD1Index -->

    <owl:AnnotationProperty rdf:about="http://data.europa.eu/949/tsiOPEAppendixD1Index">
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-11-26</terms:created>
