    <!-- http://data.europa.eu/949/nationalLoadCapability -->

    <owl:DatatypeProperty rdf:about="http://data.europa.eu/949/nationalLoadCapability">
        <rdfs:subPropertyOf rdf:resource="http://data.europa.eu/949/performanceDataParameter"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://data.europa.eu/949/CommonCharacteristicsSubset"/>
                    <rdf:Description rdf:about="http://data.europa.eu/949/RunningTrack"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <XMLName>IPP_NCLoadCap</XMLName>
        <applicable>Y/N</applicable>
        <legalDeadline xml:lang="en">16 January 2020</legalDeadline>
        <rinfIndex>1.1.1.1.2.4.1</rinfIndex>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/NationalLoadCapability"/>
        <usedInRCCCalculations rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</usedInRCCCalculations>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2020-08-24</terms:created>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2021-09-10</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-09-19</terms:modified>
        <rdfs:comment xml:lang="en">National classification for load capability</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">National classification for load capability</rdfs:label>
        <ns1:term_status>stable</ns1:term_status>
        <skos:example>The French IM SNCF reseau is using the concept of &apos;groupe Demeaux&apos; with the following definition is &apos;Groupe de classification de la voie tenant compte de la resistance de son armement en flexion verticale&apos;.</skos:example>
        <skos:scopeNote xml:lang="en">Some Networks are using National classification for load capability (instead of parameter 1.1.1.1.2.4 Load capability that provide load capability in accordance with EN 15528)</skos:scopeNote>
    </owl:DatatypeProperty>
    


