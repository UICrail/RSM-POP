        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <XMLName>EOS_DistSignToPhaseEnd</XMLName>
        <applicable>Y/N</applicable>
        <dependencyNote xml:lang="en">It is applicable ( Y ) only if the value  Overhead contact line (OCL)  is selected for parameter &quot;Type of contact line system&quot;</dependencyNote>
        <formatNote>NNN</formatNote>
        <legalDeadline xml:lang="en">16 January 2020</legalDeadline>
        <rinfIndex>1.1.1.2.4.3</rinfIndex>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/DistSignToPhaseEnd"/>
