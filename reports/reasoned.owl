<?xml version="1.0"?>
<rdf:RDF xmlns="https://cdm.ovh/rsm/pop/pop#"
     xml:base="https://cdm.ovh/rsm/pop/pop"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:dul="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:pop="https://cdm.ovh/rsm/pop/pop#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:prov="http://www.w3.org/ns/prov#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:sosa="http://www.w3.org/ns/sosa/">
    <owl:Ontology rdf:about="https://cdm.ovh/rsm/pop/pop">
        <owl:versionIRI rdf:resource="https://cdm.ovh/rsm/pop/0.2/pop"/>
        <dc:creator>Airy Magnien</dc:creator>
        <dc:date>17 June 2026</dc:date>
        <dc:description xml:lang="en">Ontology for Prescriptions (subclass of dul:Description), Observations, Predictions. Built on DUL, PROV-O, and SOSA/SSN. Also considers Specifications and Corrections (as subclasses of Prescriptions).

POPs and Current State of some Digital Twin (out of scope here) are formally similar, but epistemically quite different: POPs are facts, hence immutable. Facts can be erroneous or incomplete or obsolete, but remain as they were delivered or computed until they get discarded.</dc:description>
        <dc:license rdf:resource="https://creativecommons.org/licenses/by-sa/4.0/"/>
        <dc:title xml:lang="en">Prescription, Observation, Prediction ontology</dc:title>
        <rdfs:comment xml:lang="en">All imports were eliminated after overall consistency between DUL, SOSA/SSN, and POP was ascertained.</rdfs:comment>
        <owl:versionInfo xml:lang="en">0.2: time dimension removed (expected to be handled with dul:Situation or similar). IRI refactoring and conceptual cleanup.</owl:versionInfo>
    </owl:Ontology>
    


