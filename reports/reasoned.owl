        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <eratvIndex>4.13.2.2</eratvIndex>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/GsmRSetsInDrivingCab"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2021-08-31</terms:created>
        <terms:isRequiredBy rdf:resource="http://data.europa.eu/eli/dec_impl/2011/665/oj"/>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2021-08-31</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-02-26</terms:modified>
        <rdfs:comment xml:lang="en">Number of GSM-R mobile sets in driving cab for data transmission.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">GSM-R sets in driving cab</rdfs:label>
        <ns1:term_status>stable</ns1:term_status>
        <skos:scopeNote xml:lang="en">Allowed values: 1, 2, 3. Parameter not used when no GSM-R sets are in the cab.</skos:scopeNote>
    </owl:DatatypeProperty>
    


