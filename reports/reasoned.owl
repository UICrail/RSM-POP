    <!-- http://data.europa.eu/949/hasConnectingIM -->

    <owl:DatatypeProperty rdf:about="http://data.europa.eu/949/hasConnectingIM">
        <rdfs:subPropertyOf rdf:resource="http://data.europa.eu/949/networkStatementsDataCharacteristic"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://data.europa.eu/949/SectionOfLine"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/HasConnectingIM"/>
