        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">ETCS baseline</rdfs:label>
        <rdfs:seeAlso>TSI CCS (Table A2)</rdfs:seeAlso>
        <ns1:term_status>stable</ns1:term_status>
        <skos:scopeNote xml:lang="en">The ETCS baseline needs to be provided for each available ETCS Level. See: TSI CCS (Table A2)</skos:scopeNote>
