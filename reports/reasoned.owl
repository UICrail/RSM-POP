        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-06-03</terms:created>
        <rdfs:comment xml:lang="en">Indicates whether a primary location is a point where legal responsibility changes between Infrastructure Managers. This can be, but does not have to be, in conjunction with a state border.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">handover point flag</rdfs:label>
        <ns1:term_status>stable</ns1:term_status>
    </owl:DatatypeProperty>
    


