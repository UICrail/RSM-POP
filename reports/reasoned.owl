    <!-- http://data.europa.eu/949/tsiMagneticFields -->

    <owl:DatatypeProperty rdf:about="http://data.europa.eu/949/tsiMagneticFields">
        <rdfs:subPropertyOf rdf:resource="http://data.europa.eu/949/relatedElectromagneticInterferencesDataParameter"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://data.europa.eu/949/CommonCharacteristicsSubset"/>
                    <rdf:Description rdf:about="http://data.europa.eu/949/RunningTrack"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <XMLName>CEI_TSIMagneticFields</XMLName>
        <applicable>Y/N/NYA</applicable>
        <dependencyNote xml:lang="en">Applicable ( Y ) only when for parameter 1.1.1.3.7.1 the selected option is wheel detector. The parameter is not applicable when the rules do not exist.</dependencyNote>
        <formatNote>Y/N</formatNote>
        <legalDeadline xml:lang="en">12 months after publication of Article 7 Guide for OP tracks</legalDeadline>
        <legalDeadline xml:lang="en">In accordance with Implementing Decision 2014/880/EU and by 16 March 2019 at the latest</legalDeadline>
        <rinfIndex>1.1.1.3.9.1</rinfIndex>
        <rinfIndex>1.2.1.1.8.1</rinfIndex>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/TsiMagneticFields"/>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/TsiMagneticFieldsApplicability"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-04-18</terms:created>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-09-19</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-02-18</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-02-28</terms:modified>
        <terms:relation rdf:resource="http://data.europa.eu/949/trainDetectionSystemType"/>
        <terms:replaces rdf:resource="http://data.europa.eu/949/TSIMagneticFields"/>
        <terms:source rdf:resource="http://data.europa.eu/eli/reg_impl/2023/1695/oj"/>
        <rdfs:comment xml:lang="en">Indication whether rules exist and are compliant with the TSI.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">Existence and TSI compliance of rules for magnetic fields emitted by a vehicle</rdfs:label>
        <rdfs:seeAlso rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://www.era.europa.eu/system/files/2023-09/index077_-_ERA_ERTMS_033281_v5.pdf</rdfs:seeAlso>
        <ns1:term_status>stable</ns1:term_status>
        <skos:scopeNote xml:lang="en">The electromagnetic fields generated by rolling stock can interfere with the operation of axle counters and wheel detectors.
                      &apos;True&apos; means the rules exist and are compliant with the frequency management specified in the TSI.
                      &apos;False&apos; means the rules exist and are not compliant with the frequency management specified in the TSI.

                      Verification of compliance with TSI includes application of notified national rules (when they exist) in case of part covered by open point.</skos:scopeNote>
    </owl:DatatypeProperty>
    


    <!-- http://data.europa.eu/949/tsiSwitchCrossing -->

    <owl:DatatypeProperty rdf:about="http://data.europa.eu/949/tsiSwitchCrossing">
        <rdfs:subPropertyOf rdf:resource="http://data.europa.eu/949/switchesAndCrossingsDataParameter"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://data.europa.eu/949/CommonCharacteristicsSubset"/>
                    <rdf:Description rdf:about="http://data.europa.eu/949/RunningTrack"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <XMLName>ISC_TSISwitchCrossing</XMLName>
        <applicable>Y</applicable>
        <formatNote>in XML: Y/N</formatNote>
        <legalDeadline xml:lang="en">In accordance with Implementing Decision 2014/880/EU and by 16 March 2019 at the latest</legalDeadline>
        <rinfIndex>1.1.1.1.5.1</rinfIndex>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/TSISwitchCrossing"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2021-08-03</terms:created>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2021-09-10</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-09-19</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-02-28</terms:modified>
        <terms:source rdf:resource="http://data.europa.eu/eli/reg/2014/1299/2023-09-28"/>
        <rdfs:comment xml:lang="en">Switches and crossings are maintained to in service limit dimension as specified in TSI.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">TSI compliance of in-service values for switches and crossings</rdfs:label>
        <rdfs:seeAlso>INF TSI: 4.2.5 and 4.2.8.6</rdfs:seeAlso>
        <ns1:term_status>stable</ns1:term_status>
        <skos:scopeNote xml:lang="en">If for existing track at least one parameter has less strict value than specified in the TSI, then &apos;N&apos; (false) shall be selected.</skos:scopeNote>
    </owl:DatatypeProperty>
    


