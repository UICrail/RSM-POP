        <applicable>Y/N</applicable>
        <dependencyNote xml:lang="en">Mandatory value to be provided when 1.1.1.1.6.3 / Use of magnetic brakes is &apos;allowed under conditions&apos; or &apos;allowed under conditions only for emergency brake&apos;.</dependencyNote>
        <legalDeadline xml:lang="en">16 January 2020</legalDeadline>
        <rinfIndex>1.1.1.1.6.5</rinfIndex>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/MagneticBrakingConditionsDocument"/>
