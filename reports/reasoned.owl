        <inSkosConceptScheme rdf:resource="http://data.europa.eu/949/concepts/etcs-rbc-reject-reasons/ETCSRBCRejectionReasons"/>
        <legalDeadline xml:lang="en">12 months after publication of Article 7 Guide</legalDeadline>
        <rinfIndex>1.1.1.3.2.15</rinfIndex>
        <rinfIndex>1.2.1.1.1.15</rinfIndex>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/ReasonsEtcsRadioBlockCenterReject"/>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/ReasonsEtcsRadioBlockCenterRejectSKOS"/>
        <tsiOPEAppendixD3Index>1.4</tsiOPEAppendixD3Index>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-11-07</terms:created>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2023-03-14</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-04-18</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-09-19</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-02-27</terms:modified>
        <terms:relation rdf:resource="http://data.europa.eu/949/etcsLevelType"/>
        <terms:source rdf:resource="http://data.europa.eu/eli/reg_impl/2023/1695/oj"/>
        <rdfs:comment xml:lang="en">List of cases subject to system design choices made by the infrastructure manager according to the specification referenced in Appendix A-1, index [C]</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">Reasons for which an ETCS Radio Block Center can reject a train</rdfs:label>
        <rdfs:seeAlso rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://www.era.europa.eu/domains/technical-specifications-interoperability/control-command-and-signalling-tsi_en#oe-content-paragraph-1632</rdfs:seeAlso>
        <ns1:term_status>stable</ns1:term_status>
        <skos:scopeNote xml:lang="en">1. Distinguish between mandatory and optional: decision was only to record the mandatory ones, but optional reasons can be added.
2. Providing the non-implemented CR-solution which have been accepted by IM, after check/approval with RU&apos;s, is also allowed.</skos:scopeNote>
    </owl:ObjectProperty>
    


