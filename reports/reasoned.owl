        <applicable>Y/N</applicable>
        <dependencyNote xml:lang="en">When `not electrified` is chosen in parameter 1.1.1.2.2.1.1, then this parameter is not applicable. </dependencyNote>
        <inSkosConceptScheme rdf:resource="http://data.europa.eu/949/concepts/regenerative-braking/RegenerativeBraking"/>
        <legalDeadline xml:lang="en">In accordance with Implementing Decision 2014/880/EU and by 16 March 2019 at the latest</legalDeadline>
        <rinfIndex>1.1.1.2.2.4</rinfIndex>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/ConditionalRegenerativeBrake"/>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/ConditionalRegenerativeBrakeSKOS"/>
        <tsiOPEAppendixD2Index>3.3.7</tsiOPEAppendixD2Index>
        <usedInRCCCalculations rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</usedInRCCCalculations>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2020-08-24</terms:created>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2023-01-20</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-09-25</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-10</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-02-28</terms:modified>
        <terms:relation rdf:resource="http://data.europa.eu/949/contactLineSystemType"/>
        <rdfs:comment xml:lang="en">Indication whether regenerative braking is permitted, not permitted, or permitted under specific conditions.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">Permission for regenerative braking</rdfs:label>
        <ns1:term_status>stable</ns1:term_status>
        <skos:scopeNote xml:lang="en">When regenerative braking is &quot;allowed under conditions&quot;, a document must be provided under 1.1.1.2.2.4.1.

For RINF XML data sets:
As long as the data provision through XML data sets is allowed, an XML attribute called “Set” will be used to link the value of this parameter to the parameter 1.1.1.2.2.1.1 / ECS_SystemType</skos:scopeNote>
    </owl:ObjectProperty>
    


    <!-- http://data.europa.eu/949/conditionsAppliedRegenerativeBraking -->

    <owl:ObjectProperty rdf:about="http://data.europa.eu/949/conditionsAppliedRegenerativeBraking">
        <rdfs:subPropertyOf rdf:resource="http://data.europa.eu/949/contactLineSystemObjParameter"/>
