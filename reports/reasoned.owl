    <rdf:Description rdf:about="http://data.europa.eu/949/gsmrConstraintsOperateOnlyInCircuitSwitch">
        <applicable>Y/N/NYA</applicable>
        <dependencyNote xml:lang="en">GSM-R and ETCS L2 must be installed for this parameter to be applicable. Multiple values are allowed.</dependencyNote>
        <legalDeadline xml:lang="en">12 months after publication of Article 7 Guide</legalDeadline>
        <rinfIndex>1.2.1.1.2.12</rinfIndex>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/GsmrConstraintsOperateOnlyInCircuitSwitch"/>
