    <!-- http://data.europa.eu/949/hasNationalRegistrationProperty -->

    <owl:ObjectProperty rdf:about="http://data.europa.eu/949/hasNationalRegistrationProperty">
        <rdfs:subPropertyOf rdf:resource="http://data.europa.eu/949/vehicleTechnicalObjCharacteristic"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://data.europa.eu/949/VehicleRegistrationCase"/>
                    <rdf:Description rdf:about="http://data.europa.eu/949/VehicleRegistrationCheck"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://data.europa.eu/949/NationalRegistrationProperty"/>
        <evrIndex>12</evrIndex>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/HasNationalRegistrationProperty"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-02-10</terms:created>
        <rdfs:comment xml:lang="en">Links a vehicle registration case to a national-level registration property defined by a member state. Each member state may define its own set of such properties, identified by a national property identifier string. This avoids creating individual era: predicates for each member-state-specific registration field.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">has national registration property</rdfs:label>
        <ns1:term_status>unstable</ns1:term_status>
        <skos:altLabel xml:lang="en">has additional field</skos:altLabel>
        <skos:editorialNote xml:lang="en">Domain:
- For all additional fields COMMON to all vehicles in the CASE:  era:VehicleRegistrationCase;
- For any additional fields which would be ONLY applicable to an INDIVIDUAL Vehicle: era:VehicleRegistrationCheck.</skos:editorialNote>
    </owl:ObjectProperty>
    


