    <!-- http://data.europa.eu/949/length -->

    <owl:DatatypeProperty rdf:about="http://data.europa.eu/949/length">
        <unitOfMeasure rdf:resource="http://qudt.org/vocab/unit/M"/>
        <usedInRCCCalculations rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</usedInRCCCalculations>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2021-04-01</terms:created>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-01-08</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-11-04</terms:modified>
        <rdfs:comment xml:lang="en">Generic super-property for different types of length</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">Length</rdfs:label>
        <rdfs:seeAlso>ERA</rdfs:seeAlso>
        <ns1:term_status>stable</ns1:term_status>
        <skos:scopeNote xml:lang="en">Position of the start of the walkway:  [integer] m (from the same origin point of the kilometer post.)
Lenght of the walkway: [integer] m</skos:scopeNote>
        <skos:scopeNote xml:lang="en">The length can be
- a section of line (For operational length, use era:lengthOfSectionOfLine),
- a tunnel (For operational length, use era:lengthOfTunnel),
- a platform (For its usable length, use era:lengthOfPlatform),
- a siding (For its usable length, use era:lengthOfSiding), and
- length of other areas such as
  - a non-stopping area (accuracy +- 10m),
  - a walkway,
  - an evacuation and rescue point.
- a vehicle length.</skos:scopeNote>
    </owl:DatatypeProperty>
    


