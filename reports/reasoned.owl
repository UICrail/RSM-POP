        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/SCBOrganisationIsFromRUShape"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-06-03</terms:created>
        <rdfs:comment xml:lang="en">Relates the Organisation role instance (the role played by an Organisation)  with the specific role in the taxonomy of organisation roles.</rdfs:comment>
