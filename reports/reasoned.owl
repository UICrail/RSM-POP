        <terms:isRequiredBy rdf:resource="http://data.europa.eu/eli/dec_impl/2011/665/oj"/>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2021-08-24</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-02-14</terms:modified>
        <terms:source rdf:resource="http://data.europa.eu/eli/dec_impl/2011/665"/>
        <rdfs:comment xml:lang="en">Maximum speed when empty</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">Maximum speed empty</rdfs:label>
        <rdfs:seeAlso rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://www.era.europa.eu/system/files/2022-11/list_harmonised_national_restriction_codes_en.pdf</rdfs:seeAlso>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
        <ns1:term_status>stable</ns1:term_status>
        <skos:note xml:lang="en">Harmonised restriction code 1.3.X, with X all speed restrictions (on the given network) in km/h (empty)</skos:note>
    </owl:DatatypeProperty>
    


