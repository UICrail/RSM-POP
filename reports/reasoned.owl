        <rdfs:seeAlso rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://eur-lex.europa.eu/eli/dir/2016/797/oj/eng#art_2</rdfs:seeAlso>
        <skos:scopeNote xml:lang="en">Not applicable for Authorisation Cases of `vpa:permissionType era-va-authcase:PRE4RP`.</skos:scopeNote>
    </owl:ObjectProperty>
    


    <!-- http://data.europa.eu/949/atoCommunicationSystem -->

    <owl:ObjectProperty rdf:about="http://data.europa.eu/949/atoCommunicationSystem">
        <rdfs:subPropertyOf rdf:resource="http://data.europa.eu/949/automatedTrainOperationObjParameter"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://data.europa.eu/949/CommonCharacteristicsSubset"/>
                    <rdf:Description rdf:about="http://data.europa.eu/949/RunningTrack"/>
                    <rdf:Description rdf:about="http://data.europa.eu/949/VehicleType"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <XMLName>CAO_ATOCommSystem</XMLName>
        <applicable>Y/N/NYA</applicable>
        <dependencyNote xml:lang="en">Parameter only applicable when ETCS Baseline &gt; 4 MR1 and ATO is implemented</dependencyNote>
        <eratvIndex>4.13.2.9</eratvIndex>
        <inSkosConceptScheme rdf:resource="http://data.europa.eu/949/concepts/ato-commsys/ATOCommSystem"/>
        <legalDeadline xml:lang="en">12 months after publication of Article 7 Guide</legalDeadline>
        <rinfIndex>1.1.1.3.13.3</rinfIndex>
        <rinfIndex>1.2.1.1.10.3</rinfIndex>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/eratv/shapes/AtoCommunicationSystem"/>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/eratv/shapes/AtoCommunicationSystemSKOS"/>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/AtoCommunicationSystem"/>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/AtoCommunicationSystemSKOS"/>
