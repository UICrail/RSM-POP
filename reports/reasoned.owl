    <!-- http://data.europa.eu/949/otherCantDeficiencyBasicSSP -->

    <owl:ObjectProperty rdf:about="http://data.europa.eu/949/otherCantDeficiencyBasicSSP">
        <rdfs:subPropertyOf rdf:resource="http://data.europa.eu/949/tsiCompliantTrainProtectionSystemObjParameter"/>
