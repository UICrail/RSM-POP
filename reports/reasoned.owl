        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/NonCodedRestrictionsEVR"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-06-15</terms:created>
