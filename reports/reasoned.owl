    <!-- http://data.europa.eu/949/highSpeedLoadModelCompliance -->

    <owl:DatatypeProperty rdf:about="http://data.europa.eu/949/highSpeedLoadModelCompliance">
        <rdfs:subPropertyOf rdf:resource="http://data.europa.eu/949/performanceDataParameter"/>
