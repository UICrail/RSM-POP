        <rdfs:domain rdf:resource="http://data.europa.eu/949/Tunnel"/>
        <rdfs:range rdf:resource="http://www.opengis.net/ont/sf#Point"/>
        <XMLName>SOLTunnelStart</XMLName>
        <legalDeadline xml:lang="en">In accordance with Implementing Decision 2014/880/EU and by 16 March 2019 at the latest</legalDeadline>
        <rinfIndex>1.1.1.1.8.3</rinfIndex>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/StartLocation"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2020-07-29</terms:created>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-02-05</terms:modified>
        <rdfs:comment xml:lang="en">Part of the Start of tunnel that indicates the Geographical coordinates according to the standard World Geodetic System (WGS). Precision for both geographical latitude and geographical longitude is assumed as [NN.NNNNNNN] in degrees with decimals what gives discretion of 10 cm in the network.
The Start of tunnel is the Geographical coordinates in decimal degrees and km of the line at the beginning of a tunnel.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">Start of tunnel location</rdfs:label>
        <ns1:term_status>stable</ns1:term_status>
    </owl:ObjectProperty>
    


