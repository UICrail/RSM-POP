        <rinfIndex>1.1.1.3.8.3</rinfIndex>
        <rinfIndex>1.2.1.1.7.3</rinfIndex>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/ConditionsSwitchClassBSystems"/>
