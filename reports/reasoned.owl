    <!-- http://data.europa.eu/949/trackId -->

    <owl:DatatypeProperty rdf:about="http://data.europa.eu/949/trackId">
        <rdfs:subPropertyOf rdf:resource="http://data.europa.eu/949/trackGenericDataParameter"/>
        <rdfs:subPropertyOf rdf:resource="http://purl.org/dc/terms/identifier"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://data.europa.eu/949/RunningTrack"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <XMLName>OPTrackIdentification</XMLName>
        <XMLName>SOLTrackIdentification</XMLName>
        <applicable>Y</applicable>
        <legalDeadline xml:lang="en">In accordance with Implementing Decision 2014/880/EU and by 16 March 2019 at the latest</legalDeadline>
        <rinfIndex>1.1.1.0.0.1</rinfIndex>
        <rinfIndex>1.2.1.0.0.2</rinfIndex>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/NoRepeatedTrackIdsOP"/>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/NoRepeatedTrackIdsSoL"/>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/TrackId"/>
        <tsiOPEAppendixD2Index>2.2.1.1</tsiOPEAppendixD2Index>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2021-09-09</terms:created>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-01-08</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-09-19</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-03-08</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-03-11</terms:modified>
        <terms:source rdf:resource="http://data.europa.eu/eli/reg_impl/2019/773/oj"/>
        <rdfs:comment xml:lang="en">Unique track identification or unique track number within operational point or section of line</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">Identification of track</rdfs:label>
        <ns1:term_status>stable</ns1:term_status>
        <skos:scopeNote xml:lang="en">Each track shall have unique identification or number within the SoL. This number cannot be used for naming any other track in the same SoL.
The check regarding the uniqueness of the ID within the SoL has to be done on national level (preferably by IM).</skos:scopeNote>
    </owl:DatatypeProperty>
    


