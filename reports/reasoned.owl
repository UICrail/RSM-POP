        <inSkosConceptScheme rdf:resource="http://data.europa.eu/949/concepts/profile-num-semi-trailers/ProfileNumbersSemiTrailers"/>
        <legalDeadline xml:lang="en">by 16 March 2019 at the latest for lines belonging to the TEN (1.1.1.1.2.1)</legalDeadline>
        <rinfIndex>1.1.1.1.3.5</rinfIndex>
