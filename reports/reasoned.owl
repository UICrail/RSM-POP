        <ns1:term_status>stable</ns1:term_status>
        <skos:scopeNote xml:lang="en">To be expressed in A/m. Verification of compliance with TSI includes application of notified national rules (when they exist).

Evaluation parameters must be added if preferred bands are not used. </skos:scopeNote>
    </owl:DatatypeProperty>
    


