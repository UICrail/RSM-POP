    <!-- http://data.europa.eu/949/areaBoardingAid -->

    <owl:DatatypeProperty rdf:about="http://data.europa.eu/949/areaBoardingAid">
        <rdfs:subPropertyOf rdf:resource="http://data.europa.eu/949/platformDataParameter"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://data.europa.eu/949/CommonCharacteristicsSubset"/>
                    <rdf:Description rdf:about="http://data.europa.eu/949/PlatformEdge"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <XMLName>IPL_AreaBoardingAid</XMLName>
        <applicable>Y/N</applicable>
        <legalDeadline xml:lang="en">In accordance with Implementing Decision 2014/880/EU and by 16 March 2019 at the latest</legalDeadline>
        <rinfIndex>1.2.1.0.6.7</rinfIndex>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/AreaBoardingAid"/>
        <unitOfMeasure rdf:resource="http://qudt.org/vocab/unit/MilliM"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2021-08-02</terms:created>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2023-01-20</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-03-11</terms:modified>
        <rdfs:comment xml:lang="en">Information of the train access level for which the boarding aid can be used.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">Range of use of the platform boarding aid</rdfs:label>
        <ns1:term_status>stable</ns1:term_status>
        <skos:scopeNote xml:lang="en">Information of the train access level for which the boarding aid can be used. Data is presented as the vertical difference that is overcome by the platform boarding aid in millimetres. The value “0” means that the platform is not equipped with a platform boarding aid.</skos:scopeNote>
    </owl:DatatypeProperty>
    


