        <terms:source rdf:resource="http://data.europa.eu/eli/reg_impl/2023/1695/oj"/>
        <rdfs:comment xml:lang="en">Indication whether a switch over between different systems whilst running exists.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">Existence of switch over between different protection, control and warning systems while running</rdfs:label>
        <ns1:term_status>stable</ns1:term_status>
        <skos:scopeNote xml:lang="en">Switch over between different systems whilst running. Installation depends on local conditions. </skos:scopeNote>
    </owl:DatatypeProperty>
    


    <!-- http://data.europa.eu/949/switchRadioSystem -->

    <owl:DatatypeProperty rdf:about="http://data.europa.eu/949/switchRadioSystem">
