    <!-- http://data.europa.eu/949/dNvovtrp -->

    <owl:DatatypeProperty rdf:about="http://data.europa.eu/949/dNvovtrp">
        <rdfs:subPropertyOf rdf:resource="http://data.europa.eu/949/etcsNationalValuesDataParameter"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://data.europa.eu/949/CommonCharacteristicsSubset"/>
                    <rdf:Description rdf:about="http://data.europa.eu/949/ETCS"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range>
            <rdfs:Datatype>
                <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
                <owl:withRestrictions rdf:parseType="Collection">
                    <rdf:Description>
                        <xsd:minInclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">0.0</xsd:minInclusive>
                    </rdf:Description>
                    <rdf:Description>
                        <xsd:maxInclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">327670.0</xsd:maxInclusive>
                    </rdf:Description>
                </owl:withRestrictions>
            </rdfs:Datatype>
        </rdfs:range>
        <applicable>Y/N/NYA</applicable>
        <dependencyNote xml:lang="en">A value has to be provided when ETCS is present (a value is provided on 1.1.1.3.2.1).</dependencyNote>
        <formatNote>NNNNNNN.N whereby the last digit is only used when Q_SCALE = 10 CM</formatNote>
        <legalDeadline xml:lang="en">12 months after publication of Article 7 Guide</legalDeadline>
        <rinfIndex>1.1.1.3.2.16.5</rinfIndex>
        <rinfIndex>1.2.1.1.1.16.5</rinfIndex>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/DNvovtrp"/>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/DNvovtrpApplicability"/>
        <tsiOPEAppendixD3Index>1.5.5</tsiOPEAppendixD3Index>
        <unitOfMeasure rdf:resource="http://qudt.org/vocab/unit/M"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-11-07</terms:created>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-01-08</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-04-18</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-05</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-02-27</terms:modified>
        <terms:relation rdf:resource="http://data.europa.eu/949/etcsLevelType"/>
        <terms:source rdf:resource="http://data.europa.eu/eli/reg_impl/2023/1695/oj"/>
        <rdfs:comment xml:lang="en">Maximum distance for overriding the train trip in metres, according to the specification referenced in Appendix A-1, index [C].</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">D_NVOVTRP</rdfs:label>
        <rdfs:seeAlso rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://www.era.europa.eu/domains/technical-specifications-interoperability/control-command-and-signalling-tsi_en#oe-content-paragraph-1632</rdfs:seeAlso>
        <ns1:term_status>stable</ns1:term_status>
        <skos:scopeNote xml:lang="en">Precision: the value must be expressed in meter.

Depending on the chosen Q_SCALE, the maximal value will be: +327670 M, +32767 M or +3276.7 M.

As in TSI CCS Subset 26, chapter 7. 7.5.1.15 D_NVOVTRP.</skos:scopeNote>
    </owl:DatatypeProperty>
    


