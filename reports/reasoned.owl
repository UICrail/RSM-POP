        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/eratv/shapes/WheelSetGaugeSKOS"/>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/WheelSetGauge"/>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/WheelSetGaugeEVR"/>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/WheelSetGaugeSKOS"/>
        <usedInRCCCalculations rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</usedInRCCCalculations>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2020-07-29</terms:created>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-01-08</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-09-19</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-02-28</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-03-12</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-07-15</terms:modified>
        <terms:source rdf:resource="http://data.europa.eu/eli/reg/2014/1299/2023-09-28"/>
        <rdfs:comment xml:lang="en">A single value expressed in millimetres that identifies the track gauge.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">Nominal track gauge</rdfs:label>
        <rdfs:seeAlso rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://www.era.europa.eu/system/files/2022-11/list_harmonised_national_restriction_codes_en.pdf</rdfs:seeAlso>
        <rdfs:seeAlso>INF TSI: 4.2.4.1</rdfs:seeAlso>
        <ns1:term_status>stable</ns1:term_status>
        <skos:editorialNote xml:lang="en">Present and unchanged since &lt;http://data.europa.eu/eli/dec_impl/2011/665&gt;</skos:editorialNote>
        <skos:note xml:lang="en">Harmonised restriction code 2.2.X, with X depending on the selected track gauge.</skos:note>
        <skos:scopeNote xml:lang="en">In case of multi-rail track, a set of data is to be published separately to each pair of rails to be operated as separate track (the whole set of parameters for the separate track has to be delivered be careful then with the track identification). Nominal track gauges provided by the INF TSI are only 1435, 1520, 1524, 1600 and 1668.</skos:scopeNote>
    </owl:ObjectProperty>
    


