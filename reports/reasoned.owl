        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2023-03-29</terms:created>
        <terms:isReplacedBy rdf:resource="http://data.europa.eu/949/lineReferenceTunnelStart"/>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-02-05</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-09-19</terms:modified>
