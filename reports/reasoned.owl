        <rdfs:comment xml:lang="en">Part of the minimum radius of vertical curve that indicates the hollow</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">Minimum radius of vertical curve hollow</rdfs:label>
        <ns1:term_status>stable</ns1:term_status>
    </owl:DatatypeProperty>
    


    <!-- http://data.europa.eu/949/minimumWheelDiameter -->

    <owl:DatatypeProperty rdf:about="http://data.europa.eu/949/minimumWheelDiameter">
        <rdfs:subPropertyOf rdf:resource="http://data.europa.eu/949/switchesAndCrossingsDataParameter"/>
        <rdfs:subPropertyOf rdf:resource="http://data.europa.eu/949/vehicleTypeTechnicalDataCharacteristic"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://data.europa.eu/949/CommonCharacteristicsSubset"/>
                    <rdf:Description rdf:about="http://data.europa.eu/949/RunningTrack"/>
                    <rdf:Description rdf:about="http://data.europa.eu/949/VehicleType"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <XMLName>ISC_MinWheelDiaFixObtuseCrossings</XMLName>
        <applicable>Y</applicable>
        <eratvIndex>4.8.2</eratvIndex>
        <formatNote>NNN</formatNote>
        <legalDeadline xml:lang="en">In accordance with Implementing Decision 2014/880/EU and by 16 March 2019 at the latest</legalDeadline>
        <rinfIndex>1.1.1.1.5.2</rinfIndex>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/eratv/shapes/MinimumWheelDiameter"/>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/MinimumWheelDiameter"/>
        <unitOfMeasure rdf:resource="http://qudt.org/vocab/unit/MilliM"/>
        <usedInRCCCalculations rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</usedInRCCCalculations>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2020-08-24</terms:created>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2021-09-10</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-09-19</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-02-28</terms:modified>
        <terms:source rdf:resource="http://data.europa.eu/eli/reg/2014/1299/2023-09-28"/>
        <rdfs:comment xml:lang="en">Maximum unguided length of fixed obtuse crossings is based on a minimum wheel diameter in service expressed in millimetres.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">Minimum wheel diameter for fixed obtuse crossings</rdfs:label>
        <rdfs:seeAlso>INF TSI:  4.2.5.3</rdfs:seeAlso>
        <ns1:term_status>stable</ns1:term_status>
        <skos:editorialNote xml:lang="en">Present and unchanged since &lt;http://data.europa.eu/eli/dec_impl/2011/665&gt;</skos:editorialNote>
        <skos:scopeNote xml:lang="en">The minimum TSI value is 330 mm and this shall be used as a default value unless advised otherwise. If the value of the wheel diameter is bigger than 330 mm, it has to be specified.
New lines are assumed to be compliant with the TSI INF. When the line is compliant to TSI the default value of 330 mm has to be presented.</skos:scopeNote>
    </owl:DatatypeProperty>
    


