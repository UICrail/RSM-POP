        <terms:isRequiredBy rdf:resource="http://data.europa.eu/eli/dec_impl/2011/665/2019-06-16"/>
        <terms:isRequiredBy rdf:resource="http://data.europa.eu/eli/dec_impl/2011/665/2021-05-18"/>
        <terms:isRequiredBy rdf:resource="http://data.europa.eu/eli/dec_impl/2011/665/2023-09-08"/>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2021-09-12</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-04-18</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-09-19</terms:modified>
        <rdfs:comment xml:lang="en">Radio requirements used for demonstrating technical compatibility voice.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">Radio system compatibility voice</rdfs:label>
        <rdfs:seeAlso rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://www.era.europa.eu/era-folder/radio-system-compatibility-rsc-voice-and-data-documents</rdfs:seeAlso>
