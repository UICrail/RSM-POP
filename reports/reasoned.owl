        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/eratv/shapes/VoiceRadioCompatibleSKOS"/>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/VoiceRadioCompatible"/>
