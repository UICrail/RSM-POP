    <owl:ObjectProperty rdf:about="http://data.europa.eu/949/documentRestrictionPositionContactLineSeparation">
        <rdfs:subPropertyOf rdf:resource="http://data.europa.eu/949/requirementsRollingStockObjParameter"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://data.europa.eu/949/CommonCharacteristicsSubset"/>
                    <rdf:Description rdf:about="http://data.europa.eu/949/RunningTrack"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://data.europa.eu/949/Document"/>
        <XMLName>ERS_RestrictionMTDoc</XMLName>
        <applicable>Y/N/NYA</applicable>
        <legalDeadline xml:lang="en">12 months after publication of Article 7 Guide</legalDeadline>
        <rinfIndex>1.1.1.2.5.5</rinfIndex>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/DocumentRestrictionPositionContactLineSeparation"/>
