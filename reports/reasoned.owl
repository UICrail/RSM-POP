    <!-- http://data.europa.eu/949/hasLRS -->

    <owl:ObjectProperty rdf:about="http://data.europa.eu/949/hasLRS">
        <rdfs:domain rdf:resource="http://data.europa.eu/949/KilometricPost"/>
        <rdfs:range rdf:resource="http://data.europa.eu/949/LinearPositioningSystem"/>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/HasLRS"/>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/HasLrsCoordinate"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-11-29</terms:created>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-03-10</terms:modified>
        <rdfs:comment xml:lang="en">Specifies the linear referencing system to which the kilometre post is referenced. The linear referencing system is commonly the main railway line and it provides the framework for identifying the post&apos;s location along the railway line, using distance measurements rather than geographical coordinates.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">has linear referencing system</rdfs:label>
    </owl:ObjectProperty>
    


