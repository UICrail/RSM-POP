        <ns1:term_status>stable</ns1:term_status>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:AnnotationProperty>
    


    <!-- http://data.europa.eu/949/hashSource -->

    <owl:AnnotationProperty rdf:about="http://data.europa.eu/949/hashSource">
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-02-06</terms:created>
        <rdfs:comment xml:lang="en">This property indicates for each infrastructure element, the source, i.e. the identifier  or key that was input to the hash function in order to generate the hash value that is part of the hash URI.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">Hash source</rdfs:label>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:domain rdf:resource="http://data.europa.eu/949/InfrastructureElement"/>
    </owl:AnnotationProperty>
    


    <!-- http://data.europa.eu/949/inSkosConceptScheme -->

    <owl:AnnotationProperty rdf:about="http://data.europa.eu/949/inSkosConceptScheme">
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-11-17</terms:created>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-08-13</terms:modified>
        <rdfs:comment xml:lang="en">Property that links an object SKOS property to the URI of the corresponding SKOS Concept Scheme.</rdfs:comment>
