        <rdfs:domain rdf:resource="http://data.europa.eu/949/VehicleType"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/TypeVersionNumber"/>
