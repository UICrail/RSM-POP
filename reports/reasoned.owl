        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/EtcsEquipmentOnBoardLevelSKOS"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2021-08-31</terms:created>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2021-08-31</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-03-12</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-07-15</terms:modified>
        <rdfs:comment xml:lang="en">ETCS equipment on-board and its level.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">ETCS equipment level</rdfs:label>
