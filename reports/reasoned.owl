    <!-- http://data.europa.eu/949/subsetOf -->

    <owl:ObjectProperty rdf:about="http://data.europa.eu/949/subsetOf">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
