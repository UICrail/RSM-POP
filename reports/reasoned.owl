    <!-- http://data.europa.eu/949/lineReferenceTunnelEnd -->

    <owl:ObjectProperty rdf:about="http://data.europa.eu/949/lineReferenceTunnelEnd">
        <rdfs:subPropertyOf rdf:resource="http://data.europa.eu/949/tunnelObjParameter"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://data.europa.eu/949/Tunnel"/>
        <rdfs:range rdf:resource="http://data.europa.eu/949/NetPointReference"/>
        <XMLName>SOLTunnelEnd</XMLName>
        <legalDeadline xml:lang="en">In accordance with Implementing Decision 2014/880/EU and by 16 March 2019 at the latest</legalDeadline>
        <rinfIndex>1.1.1.1.8.4</rinfIndex>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/LineReferenceTunnelEnd"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-02-05</terms:created>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-09-19</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-10-24</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-11-29</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-02-18</terms:modified>
        <terms:replaces rdf:resource="http://data.europa.eu/949/tunnelKilometerEnd"/>
        <rdfs:comment xml:lang="en">Part of the End of tunnel that indicates the km of the line at the end of a tunnel.

The End of tunnel is the Geographical coordinates in decimal degrees and km of the line at the end of a tunnel.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">End of tunnel kilometer</rdfs:label>
        <ns1:term_status>stable</ns1:term_status>
        <skos:example>Kilometer=`0.270`</skos:example>
        <skos:scopeNote xml:lang="en">Parameters of this group (from 1.1.1.1.8.1 to 1.1.1.1.8.13) are only applicable if tunnels exist on the SoL</skos:scopeNote>
    </owl:ObjectProperty>
    


    <!-- http://data.europa.eu/949/lineReferenceTunnelStart -->

    <owl:ObjectProperty rdf:about="http://data.europa.eu/949/lineReferenceTunnelStart">
        <rdfs:subPropertyOf rdf:resource="http://data.europa.eu/949/tunnelObjParameter"/>
        <rdfs:domain rdf:resource="http://data.europa.eu/949/Tunnel"/>
        <rdfs:range rdf:resource="http://data.europa.eu/949/NetPointReference"/>
        <XMLName>SOLTunnelStart</XMLName>
        <applicable>Y</applicable>
        <legalDeadline xml:lang="en">In accordance with Implementing Decision 2014/880/EU and by 16 March 2019 at the latest</legalDeadline>
        <rinfIndex>1.1.1.1.8.3</rinfIndex>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/LineReferenceTunnelStart"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-02-05</terms:created>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-09-19</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-10-24</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-11-29</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-02-18</terms:modified>
        <terms:replaces rdf:resource="http://data.europa.eu/949/tunnelKilometerStart"/>
        <rdfs:comment xml:lang="en">Part of the Start of tunnel that indicates the km of the line at the beginning of a tunnel.

The Start of tunnel is the Geographical coordinates in decimal degrees and km of the line at the beginning of a tunnel.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">Start of tunnel kilometer</rdfs:label>
        <ns1:term_status>stable</ns1:term_status>
        <skos:example>Kilometer=`0.895`</skos:example>
        <skos:scopeNote xml:lang="en">Geographical coordinates according to the standard World Geodetic System (WGS).  Precision for both geographical latitude and geographical longitude is assumed as [NN.NNNNNNN] in degrees with decimals what gives discretion of 10 cm in the network.
Kilometre shall concern the national line identification given in 1.1.0.0.0.2
Location of the point which is assumed to be the beginning of the tunnel it is the point on the track centre line where is laid the vertical shadow of the extreme part of the tunnel s portal.</skos:scopeNote>
    </owl:ObjectProperty>
    


