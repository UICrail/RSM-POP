        <dependencyNote xml:lang="en">A value has to be provided when ETCS is present (a value is provided on 1.1.1.3.2.1).</dependencyNote>
        <inSkosConceptScheme rdf:resource="http://data.europa.eu/949/concepts/etcs-national-packet-44-functions/ETCSNationalPacket44Functions"/>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/EtcsNationalPacket44Function"/>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/EtcsNationalPacket44FunctionSKOS"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-11-20</terms:created>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2021-09-12</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-04-18</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-05-05</terms:modified>
        <terms:relation rdf:resource="http://data.europa.eu/949/etcsLevelType"/>
        <terms:replaces rdf:resource="http://data.europa.eu/949/etcsNationalPacket44"/>
        <terms:source rdf:resource="http://data.europa.eu/eli/reg_impl/2023/1695/oj"/>
        <rdfs:comment xml:lang="en">Indication whether data for national applications is transmitted between track and train.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">ETCS national packet 44 application implemented</rdfs:label>
        <rdfs:seeAlso rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://www.era.europa.eu/domains/technical-specifications-interoperability/control-command-and-signalling-tsi_en#oe-content-paragraph-1632</rdfs:seeAlso>
        <rdfs:seeAlso>TSI CCS (7.4.3 &amp; 6.2.4.2)</rdfs:seeAlso>
        <ns1:term_status>stable</ns1:term_status>
        <skos:scopeNote xml:lang="en">Value can be `false` or a link to the implemented functions.

Packets 44 are the means to transmit data for national applications between train and track and vice versa, using the data transmission facilities included within the ETCS.
NID_XUSER values managed by ERA in a document about ETCS variables available on ERA website. </skos:scopeNote>
    </owl:ObjectProperty>
    


