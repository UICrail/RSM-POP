        <rdfs:comment xml:lang="en">Indicates the core purpose of a railway vehicle: delivering traction, transporting goods or passengers or serving as a special vehicle.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">Vehicle category</rdfs:label>
