    </owl:Class>
    


    <!-- http://www.w3.org/ns/org#Organization -->

    <owl:Class rdf:about="http://www.w3.org/ns/org#Organization">
        <rdfs:label xml:lang="fr">Organisation</rdfs:label>
        <rdfs:label xml:lang="en">Organization</rdfs:label>
        <rdfs:label xml:lang="it">Organizzazione</rdfs:label>
        <rdfs:label xml:lang="es">organización</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/ns/org#Site -->

    <owl:Class rdf:about="http://www.w3.org/ns/org#Site"/>
    


    <!-- http://www.w3.org/ns/prov#Activity -->

    <owl:Class rdf:about="http://www.w3.org/ns/prov#Activity">
        <rdfs:label xml:lang="en">Activity</rdfs:label>
    </owl:Class>
    


    <!-- http://xmlns.com/foaf/0.1/Document -->

    <owl:Class rdf:about="http://xmlns.com/foaf/0.1/Document">
        <rdfs:label xml:lang="en">Document</rdfs:label>
    </owl:Class>
    


    <!-- http://xmlns.com/foaf/0.1/Person -->

    <owl:Class rdf:about="http://xmlns.com/foaf/0.1/Person">
        <rdfs:label xml:lang="en">Person</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/vpa#Case -->

    <owl:Class rdf:about="https://w3id.org/vpa#Case">
        <rdfs:comment xml:lang="en">A clearly separated part of a Request, identified clearly by its Scope(s). Each Case has an individual PermissionType as objective. A Request consists out of minimally one Case.</rdfs:comment>
        <rdfs:label xml:lang="en">Case</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/vpa#Compliance -->

    <owl:Class rdf:about="https://w3id.org/vpa#Compliance">
        <rdfs:comment xml:lang="en">Regroups the result of a compliance check on a specific section of an applicable Requirement as registered in Documented Evicence. If needed, links this examined section to a specific Restriction.</rdfs:comment>
        <rdfs:label xml:lang="en">Compliance</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/vpa#Evidence -->

    <owl:Class rdf:about="https://w3id.org/vpa#Evidence">
        <rdfs:label xml:lang="en">Evidence</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/vpa#EvidenceDocument -->

    <owl:Class rdf:about="https://w3id.org/vpa#EvidenceDocument">
        <rdfs:subClassOf rdf:resource="http://xmlns.com/foaf/0.1/Document"/>
        <rdfs:comment xml:lang="en">Issued by an AppropriateBody, it is the summary of its formal and accredited verification process, enabling the receiver (RequestingBody) to issue a Request for a Permission to the PermittingBody.</rdfs:comment>
        <rdfs:label xml:lang="en">Evidence Document</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/vpa#Permission -->

    <owl:Class rdf:about="https://w3id.org/vpa#Permission">
        <rdfs:comment xml:lang="en">Issued by a PermittingBody, it enables - mostly because of legal frameworks in place - the RequestingBody to execute the processes covered under these requirement frameworks.</rdfs:comment>
        <rdfs:label xml:lang="en">Permission</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/vpa#Request -->

    <owl:Class rdf:about="https://w3id.org/vpa#Request">
        <rdfs:comment xml:lang="en">Issued by a Requesting Body to a PermittingBody, and supported by at least one Case, while being supported by the necessary DocumentedEvidence, it intends to enable the reception of a Permission.</rdfs:comment>
        <rdfs:label xml:lang="en">Request</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/vpa#Requirement -->

    <owl:Class rdf:about="https://w3id.org/vpa#Requirement"/>
    


    <!-- https://w3id.org/vpa#Restriction -->

    <owl:Class rdf:about="https://w3id.org/vpa#Restriction">
        <rdfs:comment xml:lang="en">Issued by an Appropriate Body in connection with its documented evidence on a certain requirement, it contains all aspects to take into account in order to accept the DocumentedEvidence as proof, enabling the scope of the Permission. It is possible that the Restriction limits the Permission in the same way.</rdfs:comment>
        <rdfs:label xml:lang="en">Restriction</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/vpa#Scope -->

    <owl:Class rdf:about="https://w3id.org/vpa#Scope">
        <rdfs:comment xml:lang="en">A collection of Scopes together defining a Case. Scope is mostly the specific material object of the Case, where the Case groups them together.</rdfs:comment>
        <rdfs:label xml:lang="en">Scope</rdfs:label>
    </owl:Class>
    


