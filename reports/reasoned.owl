        <rinfIndex>1.2.2.0.3.3</rinfIndex>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/MinimumVerticalRadius"/>
        <unitOfMeasure rdf:resource="http://qudt.org/vocab/unit/M"/>
        <usedInRCCCalculations rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</usedInRCCCalculations>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2020-08-24</terms:created>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2023-04-05</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-09-19</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-12</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-03-11</terms:modified>
        <terms:source rdf:resource="http://data.europa.eu/eli/reg/2014/1299/2019-06-16"/>
        <rdfs:comment xml:lang="en">Radius of the smallest vertical curve expressed in metres.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">Minimum radius of vertical curve</rdfs:label>
        <rdfs:seeAlso>INF TSI: 4.2.3.54</rdfs:seeAlso>
        <ns1:term_status>stable</ns1:term_status>
        <skos:scopeNote xml:lang="en">The radius of vertical curves (except for humps in marshalling yards) shall be at least 500 m on a crest or 900 m in a hollow.</skos:scopeNote>
    </owl:ObjectProperty>
    


