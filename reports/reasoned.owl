        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-02-24</terms:modified>
        <rdfs:comment xml:lang="en">At maximum service brake: Stopping distance, Maximum deceleration, for the load condition &apos;design mass under normal payload&apos; at the design maximum speed.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">Maximum service brake</rdfs:label>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
        <ns1:term_status>archaic</ns1:term_status>
    </owl:DatatypeProperty>
    


    <!-- http://data.europa.eu/949/maximumSpeedAndCantDeficiency -->

    <owl:DatatypeProperty rdf:about="http://data.europa.eu/949/maximumSpeedAndCantDeficiency">
