    <!-- http://data.europa.eu/949/cantDeficiencyBasicSSP -->

    <owl:ObjectProperty rdf:about="http://data.europa.eu/949/cantDeficiencyBasicSSP">
        <rdfs:subPropertyOf rdf:resource="http://data.europa.eu/949/tsiCompliantTrainProtectionSystemObjParameter"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://data.europa.eu/949/CommonCharacteristicsSubset"/>
                    <rdf:Description rdf:about="http://data.europa.eu/949/RunningTrack"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <applicable>Y/N/NYA</applicable>
        <dependencyNote xml:lang="en">A value has to be provided when ETCS is present (a value is provided on 1.1.1.3.2.1).</dependencyNote>
        <inSkosConceptScheme rdf:resource="http://data.europa.eu/949/concepts/cant-deficiencies/CantDeficiencies"/>
        <legalDeadline xml:lang="en">12 months after publication of Article 7 Guide</legalDeadline>
        <rinfIndex>1.1.1.3.2.14</rinfIndex>
        <rinfIndex>1.2.1.1.1.14</rinfIndex>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/CantDeficiencyBasicSSP"/>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/CantDeficiencyBasicSSPApplicability"/>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/CantDeficiencyBasicSSPSKOS"/>
        <tsiOPEAppendixD3Index>1.3</tsiOPEAppendixD3Index>
        <unitOfMeasure rdf:resource="http://qudt.org/vocab/unit/MilliM"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2023-03-14</terms:created>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-01-08</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-04-18</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-09-19</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-02-28</terms:modified>
        <terms:relation rdf:resource="http://data.europa.eu/949/etcsLevelType"/>
        <terms:relation rdf:resource="http://data.europa.eu/949/otherCantDeficiencyBasicSSP"/>
        <terms:source rdf:resource="http://data.europa.eu/eli/reg_impl/2023/1695/oj"/>
        <rdfs:comment xml:lang="en">Essential information for railway undertakings with a worse (lower) tolerated cant deficiency than those for which the ETCS trackside provides SSP (Static Speed Profiles) in conjunction with parameter &quot;Other Cant Deficiency train categories for which the ETCS trackside is configured to provide SSP&quot;.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">Cant Deficiency used for the basic SSP</rdfs:label>
        <rdfs:seeAlso rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://www.era.europa.eu/domains/technical-specifications-interoperability/control-command-and-signalling-tsi_en#oe-content-paragraph-1632</rdfs:seeAlso>
        <ns1:term_status>stable</ns1:term_status>
        <skos:scopeNote xml:lang="en">The values indicated in millimetres correspond to tracks with UIC gauge. For tracks with a gauge different from UIC, the values provided here are the equivalent ones for UIC gauge, as the actual physical cant deficiency values differ. Please refer to parameter 1.1.1.1.4.2 for more details.
                           Subset-026 (3.11.3.2.1.1) definition:
a) The &quot;Cant Deficiency&quot; SSP categories: the cant deficiency value assigned to one category shall define the maximum speed, determined by suspension design, at which a particular train can traverse a curve and thus can be used to set a specific speed limit in a curve with regards to this category.</skos:scopeNote>
    </owl:ObjectProperty>
    


    <!-- http://data.europa.eu/949/carrierLinearElement -->

