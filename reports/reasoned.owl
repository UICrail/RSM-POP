    <!-- http://data.europa.eu/949/etcsTransmitsTrackConditions -->

    <owl:DatatypeProperty rdf:about="http://data.europa.eu/949/etcsTransmitsTrackConditions">
        <rdfs:subPropertyOf rdf:resource="http://data.europa.eu/949/tsiCompliantTrainProtectionSystemDataParameter"/>
        <rdfs:domain rdf:resource="http://data.europa.eu/949/ETCS"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <applicable>Y/N/NYA</applicable>
        <dependencyNote xml:lang="en">A value has to be provided when ETCS is present (a value is provided on 1.1.1.3.2.1).</dependencyNote>
        <legalDeadline xml:lang="en">12 months after publication of Article 7 Guide</legalDeadline>
        <rinfIndex>1.1.1.3.2.12</rinfIndex>
        <rinfIndex>1.2.1.1.1.12</rinfIndex>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/EtcsTransmitsTrackConditions"/>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/EtcsTransmitsTrackConditionsApplicability"/>
        <tsiOPEAppendixD3Index>1.1</tsiOPEAppendixD3Index>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-11-04</terms:created>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2023-03-14</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-04-18</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-02-28</terms:modified>
        <terms:relation rdf:resource="http://data.europa.eu/949/etcsLevelType"/>
        <terms:source rdf:resource="http://data.europa.eu/eli/reg_impl/2023/1695/oj"/>
        <rdfs:comment xml:lang="en">If the trackside does not provide Track Conditions, the driver will need to be informed about such conditions via alternative methods.
According to the specification referenced in Appendix A-1, index [C]</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">Is the ETCS trackside engineered to transmit Track Conditions</rdfs:label>
        <rdfs:seeAlso rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://www.era.europa.eu/domains/technical-specifications-interoperability/control-command-and-signalling-tsi_en#oe-content-paragraph-1632</rdfs:seeAlso>
        <rdfs:seeAlso>TSI CCS (Subset-026, Chapter 5, section 5.18)</rdfs:seeAlso>
        <ns1:term_status>stable</ns1:term_status>
        <skos:scopeNote xml:lang="en">According to the specification referenced in Appendix A-1, index [C]
If the trackside does not provide Track Conditions, the driver will need to be informed about such conditions via alternative methods.
In ETCS level NTC and level 0 track conditions are not managed (at least in Baseline 2)</skos:scopeNote>
    </owl:DatatypeProperty>
    


