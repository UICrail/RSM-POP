        <skos:note xml:lang="en">Harmonised restriction code 4.2</skos:note>
        <skos:scopeNote xml:lang="en">The details of any specified condition is to be specified within a non-coded restriction (e.g. concerned constituents where CV modules apply).</skos:scopeNote>
    </owl:DatatypeProperty>
    


