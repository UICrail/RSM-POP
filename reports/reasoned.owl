        <terms:source rdf:resource="http://data.europa.eu/eli/reg_impl/2019/773/oj"/>
        <rdfs:comment xml:lang="en">Indication of the side along the track where the lineside indication is positioned (left or right, or both sides).</rdfs:comment>
