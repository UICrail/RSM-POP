        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    </owl:AnnotationProperty>
    


    <!-- http://data.europa.eu/949/usedInEradis -->

    <owl:AnnotationProperty rdf:about="http://data.europa.eu/949/usedInEradis">
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-24</terms:created>
        <rdfs:comment xml:lang="en">Indicates whether a RINF parameter is used in ERADIS.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">Parameter is used in ERADIS</rdfs:label>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    </owl:AnnotationProperty>
    


    <!-- http://data.europa.eu/949/usedInRCCCalculations -->

    <owl:AnnotationProperty rdf:about="http://data.europa.eu/949/usedInRCCCalculations">
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2023-04-12</terms:created>
        <rdfs:comment xml:lang="en">Indicates whether a RINF parameter is used in Route Compatibility Check calculations according to Commission Implementing Regulation (EU) 2019/773 of 16 May 2019 on the technical specification for interoperability relating to the operation and traffic management subsystem of the rail system within the European Union and repealing Decision.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">Parameter is used in Route Compatibility Check (RCC) calculations</rdfs:label>
        <rdfs:seeAlso rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://eur-lex.europa.eu/eli/reg_impl/2019/773/oj#:~:text=Commission%20Implementing%20Regulation</rdfs:seeAlso>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    </owl:AnnotationProperty>
    


    <!-- http://data.europa.eu/949/wasInvalidatedBy -->

    <owl:AnnotationProperty rdf:about="http://data.europa.eu/949/wasInvalidatedBy">
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-06-04</terms:created>
        <rdfs:comment xml:lang="en">Annotation property used to express that a property is no more valid for a given legal regime.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">was invalidated by</rdfs:label>
        <skos:note xml:lang="en">It is recommended to use a URI for the range of this annotation</skos:note>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
    </owl:AnnotationProperty>
    


