        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/DC2TStatus"/>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/DocState"/>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/ECDStatus"/>
