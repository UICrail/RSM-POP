        <rdfs:comment xml:lang="en">Part of the phase info of a track that corresponds to the single selection of Y=yes or N=no to show if the energy supply system changes</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">Phase info change supply system</rdfs:label>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
        <ns1:term_status>stable</ns1:term_status>
        <skos:scopeNote xml:lang="en"> The phase info is the indication of required several information on phase separation.</skos:scopeNote>
    </owl:DatatypeProperty>
    


    <!-- http://data.europa.eu/949/phaseInfoDistanceType -->

    <owl:DatatypeProperty rdf:about="http://data.europa.eu/949/phaseInfoDistanceType">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://data.europa.eu/949/PhaseInfo"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
