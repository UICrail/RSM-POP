    <!-- http://data.europa.eu/949/dataRadioCompatible -->

    <owl:ObjectProperty rdf:about="http://data.europa.eu/949/dataRadioCompatible">
        <rdfs:subPropertyOf rdf:resource="http://data.europa.eu/949/tsiCompliantRadioObjParameter"/>
        <rdfs:subPropertyOf rdf:resource="http://data.europa.eu/949/vehicleTypeTechnicalObjectCharacteristic"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://data.europa.eu/949/CommonCharacteristicsSubset"/>
                    <rdf:Description rdf:about="http://data.europa.eu/949/RunningTrack"/>
                    <rdf:Description rdf:about="http://data.europa.eu/949/VehicleType"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <XMLName>CRG_RadioCompData</XMLName>
        <applicable>Y/N/NYA</applicable>
        <dependencyNote xml:lang="en">GSM-R and ETCS L2 must be installed for this parameter to be applicable.</dependencyNote>
        <eratvIndex>4.13.2.8</eratvIndex>
        <inSkosConceptScheme rdf:resource="http://data.europa.eu/949/concepts/radio-system-compatibilities-data/RadioSystemCompatibilitiesData"/>
        <legalDeadline xml:lang="en">12 months after publication of Article 7 Guide for OP tracks</legalDeadline>
        <legalDeadline xml:lang="en">16 January 2020</legalDeadline>
        <rinfIndex>1.1.1.3.3.10</rinfIndex>
        <rinfIndex>1.2.1.1.2.10</rinfIndex>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/eratv/shapes/DataRadioCompatible"/>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/eratv/shapes/DataRadioCompatibleSKOS"/>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/DataRadioCompatible"/>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/DataRadioCompatibleApplicability"/>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/DataRadioCompatibleSKOS"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2020-08-31</terms:created>
        <terms:isRequiredBy rdf:resource="http://data.europa.eu/eli/dec_impl/2011/665/2019-06-16"/>
        <terms:isRequiredBy rdf:resource="http://data.europa.eu/eli/dec_impl/2011/665/2021-05-18"/>
