        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-03-11</terms:modified>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">Other train detection systems</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://data.europa.eu/949/pantographDataParameter -->

    <owl:DatatypeProperty rdf:about="http://data.europa.eu/949/pantographDataParameter">
        <rdfs:subPropertyOf rdf:resource="http://data.europa.eu/949/energySubsystemDataParameter"/>
        <rinfIndex>1.1.1.2.3</rinfIndex>
