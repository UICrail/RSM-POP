    <!-- http://data.europa.eu/949/TSIMagneticFields -->

    <owl:ObjectProperty rdf:about="http://data.europa.eu/949/TSIMagneticFields">
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <applicable>Y/N/NYA</applicable>
        <inSkosConceptScheme rdf:resource="http://data.europa.eu/949/concepts/tsi-existence-and-compliances/TSIExistenceAndCompliances"/>
        <legalDeadline xml:lang="en">12 months after publication of Article 7 Guide</legalDeadline>
        <legalDeadline xml:lang="en">In accordance with Implementing Decision 2014/880/EU and by 16 March 2019 at the latest</legalDeadline>
        <rinfIndex>1.1.1.3.9.1</rinfIndex>
        <rinfIndex>1.2.1.1.8.1</rinfIndex>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2021-08-09</terms:created>
        <terms:isReplacedBy rdf:resource="http://data.europa.eu/949/tsiMagneticFields"/>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2021-09-12</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-04-25</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-03-04</terms:modified>
        <rdfs:comment xml:lang="en">Indication whether rules exist and are compliant with the TSI.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">Existence and TSI compliance of rules for magnetic fields emitted by a vehicle</rdfs:label>
        <rdfs:seeAlso rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://www.era.europa.eu/system/files/2023-09/index077_-_ERA_ERTMS_033281_v5.pdf</rdfs:seeAlso>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
        <ns1:term_status>stable</ns1:term_status>
    </owl:ObjectProperty>
    


    <!-- http://data.europa.eu/949/TSITractionHarmonics -->

    <owl:ObjectProperty rdf:about="http://data.europa.eu/949/TSITractionHarmonics">
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <XMLName>CEI_TSITractionHarmonics</XMLName>
        <applicable>Y/N/NYA</applicable>
        <inSkosConceptScheme rdf:resource="http://data.europa.eu/949/concepts/tsi-compliances/TSICompliances"/>
        <legalDeadline xml:lang="en">12 months after publication of Article 7 Guide for OP tracks</legalDeadline>
        <legalDeadline xml:lang="en">In accordance with Implementing Decision 2014/880/EU and by 16 March 2019 at the latest</legalDeadline>
        <rinfIndex>1.1.1.3.9.2</rinfIndex>
        <rinfIndex>1.2.1.1.8.2</rinfIndex>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2021-08-09</terms:created>
        <terms:isReplacedBy rdf:resource="http://data.europa.eu/949/tsiTractionHarmonics"/>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2021-09-12</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-03-04</terms:modified>
        <terms:source rdf:resource="http://data.europa.eu/eli/reg_impl/2023/1695/oj"/>
        <rdfs:comment xml:lang="en">Indication whether rules exist and are compliant with the TSI.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">Existence and TSI compliance of limits in harmonics in the traction current of vehicles</rdfs:label>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
        <ns1:term_status>stable</ns1:term_status>
        <skos:scopeNote xml:lang="en">Compatibility with track circuits and wheel detectors of axle counters. The harmonics in the traction current in the rails can interfere with the operation of track circuits. The DC current in the rails may saturate the detectors of the axle counters, preventing their  operation.
 none  shall be selected when respective national rules do not exist.</skos:scopeNote>
    </owl:ObjectProperty>
    


    <!-- http://data.europa.eu/949/accelerationLevelCrossing -->

    <owl:ObjectProperty rdf:about="http://data.europa.eu/949/accelerationLevelCrossing">
        <rdfs:subPropertyOf rdf:resource="http://data.europa.eu/949/healthSafetyAndEnvironmentObjParameter"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://data.europa.eu/949/CommonCharacteristicsSubset"/>
                    <rdf:Description rdf:about="http://data.europa.eu/949/Track"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://data.europa.eu/949/Document"/>
        <XMLName>IHS_AccelerationLevelCrossing</XMLName>
        <applicable>Y/N</applicable>
        <dependencyNote xml:lang="en">Mandatory value when the level crossing is defined</dependencyNote>
        <legalDeadline xml:lang="en">In accordance with Implementing Decision 2014/880/EU and by 16 March 2019 at the latest</legalDeadline>
        <rinfIndex>1.1.1.1.7.3</rinfIndex>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/AccelerationLevelCrossing"/>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/AccelerationLevelCrossingApplicability"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2021-08-03</terms:created>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-01-08</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-11-20</terms:modified>
        <rdfs:comment xml:lang="en">Existence of limit for acceleration of train if stopping or recovering speed close to a level crossing expressed in a specific reference acceleration curve.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">Acceleration allowed near level crossing</rdfs:label>
        <ns1:term_status>stable</ns1:term_status>
        <skos:scopeNote xml:lang="en">The value of this parameter should be either a reference to a file name or an external link to a document.
If a file name is provided, the Infrastructure Manager (IM) must upload a document with the same file name using the &quot;Reference Documents Management&quot; functionality in the RINF application. The document must be in electronic format and available in two official EU languages. In this case, the parameter value must be repeated for each document.
If an external link is provided, the IM must ensure that the document is available at the provided link.</skos:scopeNote>
    </owl:ObjectProperty>
    


    <!-- http://data.europa.eu/949/additionalBrakingInformationDocument -->

    <owl:ObjectProperty rdf:about="http://data.europa.eu/949/additionalBrakingInformationDocument">
        <rdfs:subPropertyOf rdf:resource="http://data.europa.eu/949/brakeRelatedObjParameter"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://data.europa.eu/949/CommonCharacteristicsSubset"/>
                    <rdf:Description rdf:about="http://data.europa.eu/949/RunningTrack"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://data.europa.eu/949/Document"/>
        <XMLName>CBP_BrakePerfDocRef</XMLName>
        <applicable>Y/N</applicable>
        <dependencyNote xml:lang="en">Only applicable when for parameter 1.1.1.3.11.2 True is selected</dependencyNote>
        <legalDeadline xml:lang="en">16 January 2020</legalDeadline>
        <rinfIndex>1.1.1.3.11.3</rinfIndex>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/AdditionalBrakingInformationDocument"/>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/AdditionalBrakingInformationDocumentApplicability"/>
        <usedInRCCCalculations rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</usedInRCCCalculations>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2020-08-24</terms:created>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-01-08</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-04-23</terms:modified>
        <rdfs:comment xml:lang="en">Electronic document available in two EU languages from the IM stored by the Agency providing additional information as defined in point (2) of point 4.2.2.6.2 of TSI OPE.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">Documents available by the IM relating to braking performance</rdfs:label>
        <ns1:term_status>stable</ns1:term_status>
        <skos:changeNote xml:lang="en">Change from datatype property to object property in order to point to the class Document (reference document)</skos:changeNote>
        <skos:scopeNote xml:lang="en">The value of this parameter should be either a reference to a file name or an external link to a document.
If a file name is provided, the Infrastructure Manager (IM) must upload a document with the same file name using the &quot;Reference Documents Management&quot; functionality in the RINF application. The document must be in electronic format and available in two official EU languages. In this case, the parameter value must be repeated for each document.
If an external link is provided, the IM must ensure that the document is available at the provided link.</skos:scopeNote>
    </owl:ObjectProperty>
    


