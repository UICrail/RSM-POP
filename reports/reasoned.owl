        <rdfs:subPropertyOf rdf:resource="http://data.europa.eu/949/contactLineSystemDataParameter"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://data.europa.eu/949/PlatformEdge"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <applicable>Y/N</applicable>
        <legalDeadline xml:lang="en">Contrary to the Regulation, the deadline is not 30 June 2024 at the latest, but 12 months after publication of Article 7 Guide</legalDeadline>
        <rinfIndex>1.2.1.0.7.1</rinfIndex>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/PermissionChargingElectricEnergyTractionStandstill"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2023-03-14</terms:created>
        <rdfs:comment xml:lang="en">Point at which IM authorises charging of electric energy storage for traction purposes at standstill.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">Permission for charging electric energy storage for traction purposes at standstill</rdfs:label>
        <ns1:term_status>stable</ns1:term_status>
    </owl:DatatypeProperty>
    


    <!-- http://data.europa.eu/949/permitUseReflectivePlates -->

    <owl:DatatypeProperty rdf:about="http://data.europa.eu/949/permitUseReflectivePlates">
        <rdfs:subPropertyOf rdf:resource="http://data.europa.eu/949/healthSafetyAndEnvironmentDataParameter"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://data.europa.eu/949/CommonCharacteristicsSubset"/>
                    <rdf:Description rdf:about="http://data.europa.eu/949/RunningTrack"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <applicable>Y/N/NYA</applicable>
        <legalDeadline xml:lang="en">12 months after publication of Article 7 Guide</legalDeadline>
        <rinfIndex>1.1.1.1.7.12</rinfIndex>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/PermitUseReflectivePlates"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2023-03-14</terms:created>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-09-22</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-01-22</terms:modified>
        <rdfs:comment xml:lang="en">Sections where is permitted to use the reflective plates on rail freight corridors, with a view to prioritise the current bottlenecks. Specific case for Belgium, France, Italy, Portugal and Spain until 1.1.2026</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">Permit of use of reflective plates</rdfs:label>
        <rdfs:seeAlso>4.2.2.1.3.2 of TSI OPE (Commission Implementing Regulation (EU) 2019/773 of 16 May 2019)</rdfs:seeAlso>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
        <ns1:term_status>archaic</ns1:term_status>
        <skos:scopeNote xml:lang="en">From TSI OPE: Member States shall in particular endeavour to permit the use of reflective plates on rail freight corridors, with a view to prioritise the current bottlenecks. These sections and details of any conditions pertaining to them shall be recorded in the RINF. Until the information is encoded in RINF, the infrastructure manager shall ensure the information is communicated to railway undertakings by other appropriate means. The infrastructure manager shall identify the sections of lines on which 2 steady red lights are required in the RINF. </skos:scopeNote>
    </owl:DatatypeProperty>
    


    <!-- http://data.europa.eu/949/permittedContactForce -->

    <owl:DatatypeProperty rdf:about="http://data.europa.eu/949/permittedContactForce">
        <rdfs:subPropertyOf rdf:resource="http://data.europa.eu/949/requirementsRollingStockDataParameter"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://data.europa.eu/949/CommonCharacteristicsSubset"/>
                    <rdf:Description rdf:about="http://data.europa.eu/949/RunningTrack"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <XMLName>ERS_ContactForce</XMLName>
        <applicable>Y/N</applicable>
        <dependencyNote xml:lang="en">A value is mandatory if the value  Overhead contact line (OCL)  is selected for parameter &quot;Type of contact line system&quot;</dependencyNote>
        <formatNote>The force is either given as: a value of the static force and of the maximum force expressed in newtons, or as a formula for function of the speed</formatNote>
        <legalDeadline xml:lang="en">In accordance with Implementing Decision 2014/880/EU and by 16 March 2019 at the latest</legalDeadline>
        <rinfIndex>1.1.1.2.5.2</rinfIndex>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/PermittedContactForce"/>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/PermittedContactForceApplicability"/>
        <unitOfMeasure rdf:resource="http://qudt.org/vocab/unit/N"/>
        <usedInRCCCalculations rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</usedInRCCCalculations>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2020-08-25</terms:created>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-01-08</terms:modified>
        <rdfs:comment xml:lang="en">Indication of contact force allowed expressed in newton.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">Contact force permitted</rdfs:label>
        <rdfs:seeAlso>LOC&amp;PAS TSI: 4.2.8.2.9.6
ENE TSI: 4.2.11
EN 50367:2020+A1:2022 Table 6</rdfs:seeAlso>
        <ns1:term_status>stable</ns1:term_status>
        <skos:scopeNote xml:lang="en">The formula of the function shall represent the curve describing the value of the contact force in relation to the speed.
Static and maximum forces are given only for the maximum permitted line speed (see parameter number 1.1.1.1.2.5).</skos:scopeNote>
    </owl:DatatypeProperty>
    


    <!-- http://data.europa.eu/949/phaseInfo -->

    <owl:DatatypeProperty rdf:about="http://data.europa.eu/949/phaseInfo">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2021-08-08</terms:created>
        <terms:isReplacedBy rdf:resource="http://data.europa.eu/949/PhaseInfo"/>
        <terms:isReplacedBy rdf:resource="http://data.europa.eu/949/phaseInfoKm"/>
        <terms:isReplacedBy rdf:resource="http://data.europa.eu/949/phaseInfoLength"/>
        <terms:isReplacedBy rdf:resource="http://data.europa.eu/949/phaseInfoPantographLowered"/>
        <terms:isReplacedBy rdf:resource="http://data.europa.eu/949/phaseInfoSwitchOffBreaker"/>
        <terms:isReplacedBy rdf:resource="http://data.europa.eu/949/trackPhaseInfo"/>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2023-04-05</terms:modified>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">Information on phase separation</rdfs:label>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
        <ns1:term_status>stable</ns1:term_status>
        <skos:editorialNote xml:lang="en"> Deprecated because of replacement by three properties. The reason is that the property is composed of three values: length [NNN] - the length of the phase separation in metres; switch off breaker [Y/N], single selection of &apos;yes&apos; or &apos;no&apos; to show whether the breaker has to be switched off; and lower pantograph [Y/N], single selection of &apos;yes&apos; or &apos;no&apos; to show whether the pantograph has to be lowered,
                   Km [NNN.NNN] - the location from the start of the line where the new value is valid.</skos:editorialNote>
    </owl:DatatypeProperty>
    


