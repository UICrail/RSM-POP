        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2023-01-23</terms:modified>
        <rdfs:comment xml:lang="en">Indicates if a certain property is TSI compliant.The reason for deprecation is that it is used in SKOS &quot;OtherPantographHeads&quot; and &quot;TsiPantographHeads&quot; to indicate in the first case if a SKOS concept is not tsiCompliant (false) and in the second case that the concept is tsiCompliant (true). These two SKOS were originally one SKOS, &quot;PantographHeads&quot;. Currently with the two SKOS the property is redundant.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">Tsi compliant</rdfs:label>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
        <ns1:term_status>stable</ns1:term_status>
    </owl:DatatypeProperty>
    


