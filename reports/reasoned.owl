    <!-- http://data.europa.eu/949/maximumAltitude -->

    <owl:DatatypeProperty rdf:about="http://data.europa.eu/949/maximumAltitude">
        <rdfs:subPropertyOf rdf:resource="http://data.europa.eu/949/performanceDataParameter"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://data.europa.eu/949/CommonCharacteristicsSubset"/>
                    <rdf:Description rdf:about="http://data.europa.eu/949/RunningTrack"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <XMLName>IPP_MaxAltitude</XMLName>
        <applicable>Y/N</applicable>
        <formatNote>[+/-][NNNN]</formatNote>
        <legalDeadline xml:lang="en">In accordance with Implementing Decision 2014/880/EU and by 16 March 2019 at the latest</legalDeadline>
        <rinfIndex>1.1.1.1.2.7</rinfIndex>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/MaximumAltitude"/>
        <unitOfMeasure rdf:resource="http://qudt.org/vocab/unit/M"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2021-08-03</terms:created>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-10-20</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-09-19</terms:modified>
        <rdfs:comment xml:lang="en">Highest point of the section of line above sea level in reference to Normal Amsterdam&apos;s Peil (NAP).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">Maximum altitude</rdfs:label>
        <ns1:term_status>stable</ns1:term_status>
        <skos:scopeNote xml:lang="en">Normaal Amsterdams Peil (NAP), called also Amsterdam Ordnance Datum, it is a vertical datum commonly in use in Europe as reference level for the description of the height of objects in relation to the sea level.

The value of the parameter shall be given in metres, with tolerance of +/-100m.</skos:scopeNote>
    </owl:DatatypeProperty>
    


