        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2021-09-12</terms:modified>
        <rdfs:comment xml:lang="en">Distance between the signboard authorizing the driver to  raise pantograph  or  close the circuit breaker  after passing the phase separation and the end of the phase separation section.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
