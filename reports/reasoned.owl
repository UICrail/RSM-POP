        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-10-27</terms:created>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-01-08</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-04-18</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-09-19</terms:modified>
        <terms:relation rdf:resource="http://data.europa.eu/949/signalId"/>
        <terms:source rdf:resource="http://data.europa.eu/eli/reg_impl/2019/773/oj"/>
        <rdfs:comment xml:lang="en">Signalling information for Route Book compilation. This list shall include fixed signals that protect danger points</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">Type of signal</rdfs:label>
        <ns1:term_status>unstable</ns1:term_status>
        <skos:scopeNote xml:lang="en">Indicates what function the signal (on the track or in OP) executes in relation to the track/switches.</skos:scopeNote>
    </owl:ObjectProperty>
    


