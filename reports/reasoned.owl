        <rdfs:subPropertyOf rdf:resource="http://data.europa.eu/949/verifiedRccObjParameter"/>
        <rdfs:domain rdf:resource="http://data.europa.eu/949/CommonCharacteristicsSubset"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://data.europa.eu/949/Document"/>
                    <rdf:Description rdf:about="http://data.europa.eu/949/VehicleType"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <applicable>Y/N/NYA</applicable>
        <legalDeadline xml:lang="en">12 months after publication of Article 7 Guide</legalDeadline>
        <rinfIndex>1.1.1.5.1</rinfIndex>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/VehicleTypesCompatibleTrafficLoad"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2023-03-14</terms:created>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-10-24</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-03-10</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-03-11</terms:modified>
        <rdfs:comment xml:lang="en">The infrastructure managers shall provide through RINF the information to the RU regarding list of vehicle types compatible with the route for which they have already verified compatibility for parameter Traffic load and load carrying capacity of infrastructure and train detection systems, where such information is available.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">List of vehicle types already identified as compatible with Traffic load and load carrying capacity of infrastructure and train detection systems</rdfs:label>
        <ns1:term_status>unstable</ns1:term_status>
    </owl:ObjectProperty>
    


