        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/VehicleTypeNumber"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-02-14</terms:created>
        <rdfs:comment xml:lang="en">Each type of vehicle shall receive a number consisting of 10 digits with the structure as in Annex III of the ERATV Decision.

For the full Vehicle Identifier, use `dcterms:identifier`.
For the complement before Fourth Railway package, use `era:includedVersions`.
For the complements after the Fourth Railway Package, use `era:includedVersionsVariant`.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">Type number</rdfs:label>
        <rdfs:seeAlso rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://eur-lex.europa.eu/eli/dec_impl/2011/665/2023-09-08#anx_III</rdfs:seeAlso>
        <ns1:term_status>stable</ns1:term_status>
        <skos:editorialNote xml:lang="en">Present and unchanged since &lt;http://data.europa.eu/eli/dec_impl/2011/665&gt;</skos:editorialNote>
    </owl:DatatypeProperty>
    


