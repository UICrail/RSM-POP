        <inSkosConceptScheme rdf:resource="http://data.europa.eu/949/concepts/legacy-radio-systems/LegacyRadioSystems"/>
        <legalDeadline xml:lang="en">12 months after publication of Article 7 Guide for OP tracks</legalDeadline>
        <legalDeadline xml:lang="en">16 January 2020</legalDeadline>
        <rinfIndex>1.1.1.3.6.1</rinfIndex>
        <rinfIndex>1.2.1.1.5.1</rinfIndex>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/eratv/shapes/LegacyRadioSystem"/>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/eratv/shapes/LegacyRadioSystemSKOS"/>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/LegacyRadioSystem"/>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/LegacyRadioSystemEVR"/>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/LegacyRadioSystemSKOS"/>
        <tsiOPEAppendixD2Index>3.1.7</tsiOPEAppendixD2Index>
        <usedInRCCCalculations rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</usedInRCCCalculations>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2020-08-31</terms:created>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2021-09-12</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-04-18</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-09-19</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-02-26</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-07-15</terms:modified>
        <terms:source rdf:resource="http://data.europa.eu/eli/reg_impl/2019/773/oj"/>
        <terms:source rdf:resource="http://data.europa.eu/eli/reg_impl/2023/1695/oj"/>
        <rdfs:comment xml:lang="en">Indication of radio legacy systems installed.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">Class B or other radio systems installed (Radio Legacy Systems)</rdfs:label>
        <rdfs:seeAlso rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX%3A32023R1695&amp;qid=1694158367331#d1295e32-554-1</rdfs:seeAlso>
        <rdfs:seeAlso rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://www.era.europa.eu/system/files/2022-11/list_harmonised_national_restriction_codes_en.pdf</rdfs:seeAlso>
        <ns1:term_status>stable</ns1:term_status>
        <skos:editorialNote xml:lang="en">Present and unchanged since &lt;http://data.europa.eu/eli/dec_impl/2011/665&gt;</skos:editorialNote>
        <skos:note xml:lang="en">Harmonised restriction code 2.5</skos:note>
        <skos:scopeNote xml:lang="en">The list is in line with ERA/TD/2011-09/INT (v1.17), Table 4, and is now in 3.4 of the annex II of TSI CCS.</skos:scopeNote>
    </owl:ObjectProperty>
    


