    <!-- http://data.europa.eu/949/trainDetectionSystem -->

    <owl:ObjectProperty rdf:about="http://data.europa.eu/949/trainDetectionSystem">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://data.europa.eu/949/CommonCharacteristicsSubset"/>
                    <rdf:Description rdf:about="http://data.europa.eu/949/RunningTrack"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://data.europa.eu/949/TrainDetectionSystem"/>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/TrainDetectionSystem"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2020-07-29</terms:created>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2021-09-12</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-02-28</terms:modified>
        <rdfs:comment xml:lang="en">Technical characteristics of the train detection systems installed in the section of line.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">train detection system</rdfs:label>
        <ns1:term_status>stable</ns1:term_status>
        <skos:scopeNote xml:lang="en">It can be repeated as many times as the number of different train detection systems are present.
Not all parameters are applicable to all types of train detection systems; it depends on the applicability condition.
For RDF data provision:
The value of this property is an instance of the era:TrainDetectionsystem, which has as properties the parameters with indices 1.1.1.3.7.x.

For RINF XML data sets:
As long as the data provision through XML data sets is allowed, this property is the equivalent of the &quot;Set&quot; attribute, grouping parameters 1.1.1.3.7.x.</skos:scopeNote>
    </owl:ObjectProperty>
    


    <!-- http://data.europa.eu/949/trainDetectionSystemBasedFrequencyBandsObjParameter -->

    <owl:ObjectProperty rdf:about="http://data.europa.eu/949/trainDetectionSystemBasedFrequencyBandsObjParameter">
        <rdfs:subPropertyOf rdf:resource="http://data.europa.eu/949/ccsSubsystemObjParameter"/>
        <rinfIndex>1.1.1.3.4</rinfIndex>
        <rinfIndex>1.2.1.1.3</rinfIndex>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-10-31</terms:created>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">Train detection systems defined based on frequency bands</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://data.europa.eu/949/trainDetectionSystemSpecificCheck -->

    <owl:ObjectProperty rdf:about="http://data.europa.eu/949/trainDetectionSystemSpecificCheck">
