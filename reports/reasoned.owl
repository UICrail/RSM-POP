    <!-- http://data.europa.eu/949/gradient -->

    <owl:DatatypeProperty rdf:about="http://data.europa.eu/949/gradient">
        <rdfs:subPropertyOf rdf:resource="http://data.europa.eu/949/sidingDataParameter"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
