        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://data.europa.eu/949/gsmrErrorCorrectionsOnboard -->

    <owl:DatatypeProperty rdf:about="http://data.europa.eu/949/gsmrErrorCorrectionsOnboard">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2023-03-14</terms:created>
        <terms:isReplacedBy rdf:resource="http://data.europa.eu/949/errorCorrectionsOnboard"/>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-01-08</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-04-18</terms:modified>
        <rdfs:comment xml:lang="en">List of unacceptable errors impacting the IM network that are required to be solved in the on-board according to the CCS TSI point 7.2.10.3 specification maintenance point.
The reason for deprecation is that this parameter does not appear in the latest legal text.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">(Deprecated) GSM-R error corrections required for the on-board</rdfs:label>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
        <ns1:term_status>stable</ns1:term_status>
    </owl:DatatypeProperty>
    


    <!-- http://data.europa.eu/949/gsmrForcedDeregistrationFunctionalNumber -->

    <owl:DatatypeProperty rdf:about="http://data.europa.eu/949/gsmrForcedDeregistrationFunctionalNumber">
        <rdfs:subPropertyOf rdf:resource="http://data.europa.eu/949/tsiCompliantRadioDataParameter"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://data.europa.eu/949/CommonCharacteristicsSubset"/>
                    <rdf:Description rdf:about="http://data.europa.eu/949/RunningTrack"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <applicable>Y/N/NYA</applicable>
        <dependencyNote xml:lang="en">GSM-R and ETCS L2 must be installed for this parameter to be applicable.</dependencyNote>
        <legalDeadline xml:lang="en">12 months after publication of Article 7 Guide</legalDeadline>
        <rinfIndex>1.1.1.3.3.11</rinfIndex>
        <rinfIndex>1.2.1.1.2.11</rinfIndex>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/GsmrForcedDeregistrationFunctionalNumber"/>
        <shaclShapeValidationRule rdf:resource="http://data.europa.eu/949/shapes/GsmrForcedDeregistrationFunctionalNumberApplicability"/>
        <tsiOPEAppendixD3Index>2.1</tsiOPEAppendixD3Index>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-11-07</terms:created>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2023-03-14</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-04-18</terms:modified>
        <terms:relation rdf:resource="http://data.europa.eu/949/etcsLevelType"/>
        <terms:source rdf:resource="http://data.europa.eu/eli/reg_impl/2023/1695/oj"/>
        <rdfs:comment xml:lang="en">This feature will determine the applicable operational rules for drivers and signallers when dealing with cab radios registered under wrong numbers.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">GSM-R network is configured to allow forced de-registration of a functional number by another driver</rdfs:label>
        <ns1:term_status>stable</ns1:term_status>
        <skos:scopeNote xml:lang="en">See documents regarding Operational Harmonisation ETCS.</skos:scopeNote>
    </owl:DatatypeProperty>
    


    <!-- http://data.europa.eu/949/handoverPointFlag -->

    <owl:DatatypeProperty rdf:about="http://data.europa.eu/949/handoverPointFlag">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://data.europa.eu/949/PrimaryLocation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
