        <terms:source rdf:resource="http://data.europa.eu/eli/reg/2014/1302/2023-09-28"/>
        <terms:source rdf:resource="http://data.europa.eu/eli/reg_impl/2023/1694/oj"/>
        <rdfs:comment xml:lang="en">Presence of derailment prevention and detection by signal processing.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">Has onboard DDF/DPF</rdfs:label>
        <ns1:term_status>stable</ns1:term_status>
        <skos:scopeNote xml:lang="en">Only applicable for Traction Locomotives, intended to process signals emitted by freight wagons, if provided with Derailment Prevention Function (‘DPF’) or Derailment Detection Function (‘DDF’) as defined in point 4.2.3.5.3 of TSI WAG.</skos:scopeNote>
    </owl:DatatypeProperty>
    


