        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-03-04</terms:modified>
        <terms:relation rdf:resource="http://data.europa.eu/949/etcsLevelType"/>
        <terms:source rdf:resource="http://data.europa.eu/eli/reg_impl/2019/773/2023-09-28"/>
        <terms:source rdf:resource="http://data.europa.eu/eli/reg_impl/2023/1695/oj"/>
        <rdfs:comment xml:lang="en">Indication of existence of other system than ETCS for degraded situation.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
        <rdfs:label xml:lang="en">Other train protection, control and warning systems for degraded situation</rdfs:label>
