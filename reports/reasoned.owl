        <eratvIndex>4.1.3</eratvIndex>
        <evrIndex>11.9.1</evrIndex>
        <inSkosConceptScheme rdf:resource="http://data.europa.eu/949/concepts/nominal-track-gauges/NominalTrackGauges"/>
        <legalDeadline xml:lang="en">In accordance with Implementing Decision 2014/880/EU and by 16 March 2019 at the latest</legalDeadline>
        <rinfIndex>1.1.1.1.4.1</rinfIndex>
        <rinfIndex>1.2.1.0.4.1</rinfIndex>
