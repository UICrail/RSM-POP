    </owl:DatatypeProperty>
    


    <!-- http://data.europa.eu/949/idPhoneErtmsRadioBlockCenter -->

    <owl:DatatypeProperty rdf:about="http://data.europa.eu/949/idPhoneErtmsRadioBlockCenter">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <applicable>Y/N/NYA</applicable>
        <dependencyNote xml:lang="en">A value has to be provided when ETCS is present (a value is provided on 1.1.1.3.2.1).</dependencyNote>
        <legalDeadline xml:lang="en">12 months after publication of Article 7 Guide</legalDeadline>
        <rinfIndex>1.1.1.3.2.17</rinfIndex>
        <rinfIndex>1.2.1.1.1.17</rinfIndex>
