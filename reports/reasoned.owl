    </owl:AnnotationProperty>
    


    <!-- http://data.europa.eu/949/formatNote -->

    <owl:AnnotationProperty rdf:about="http://data.europa.eu/949/formatNote">
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-03</terms:created>
        <rdfs:comment xml:lang="en">This property is used to annotate in human readable the format of parameters</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/949/"/>
